#!/bin/bash

export DISABLE_AUTOUPDATER=1

bootstrap_dirs=(
  "$HOME/.cline"
  "$HOME/.config/crush"
  "$HOME/.config/crush/skills"
  "$HOME/.config/goose"
  "$HOME/.config/gptme"
  "$HOME/.config/gptme/lessons"
  "$HOME/.config/manicode"
  "$HOME/.config/manicode/projects"
  "$HOME/.config/nanocoder"
  "$HOME/.local/share/crush"
  "$HOME/.local/share/goose"
  "$HOME/.local/share/gptme"
  "$HOME/.local/share/nanocoder"
  "$HOME/.neovate"
  "$HOME/.qwen"
)

ensure_dir() {
  local dir="$1"

  if [ ! -d "$dir" ]; then
    mkdir -p "$dir"
    echo "✓ created $dir"
  fi
}

echo "[setup-ai-tool] Ensuring agent CLI directories exist..."
for dir in "${bootstrap_dirs[@]}"; do
  ensure_dir "$dir"
done

configure_claude_mcp() {
  local mcp_list
  mcp_list=$(claude mcp list 2>/dev/null)

  mcp_exists() {
    local name="$1"
    grep -Fq "\"$name\"" <<<"$mcp_list"
  }

  local mcp_names=(
    "deepwiki"
    "modular-mcp"
  )
  local mcp_args=(
    "-s user -t http deepwiki https://mcp.deepwiki.com/mcp"
    "--transport stdio -s user modular-mcp -- npx -y @kimuson/modular-mcp $HOME/.claude/modular-mcp.json"
  )

  add_or_skip_mcp() {
    local name="$1"
    local args="$2"

    if ! mcp_exists "$name"; then
      echo "Adding $name MCP..."
      local output
      if output=$(eval "claude mcp add $args" 2>&1); then
        echo "✔ $name MCP added"
        return 0
      elif grep -q "already exists" <<<"$output"; then
        echo "✓ $name MCP already registered"
        return 0
      else
        echo "✖ Failed to add $name MCP"
        echo "$output"
        return 1
      fi
    else
      echo "✓ $name MCP already registered"
      return 0
    fi
  }

  echo "[setup-ai-tool] Configuring Claude MCPs..."
  for i in "${!mcp_names[@]}"; do
    if ! add_or_skip_mcp "${mcp_names[$i]}" "${mcp_args[$i]}"; then
      return 1
    fi
  done
}

if command -v claude >/dev/null 2>&1; then
  if ! configure_claude_mcp; then
    exit 1
  fi
else
  echo "[setup-ai-tool] Skipping Claude MCP setup because 'claude' is not installed."
fi

if command -v neovate >/dev/null 2>&1; then
  echo "[setup-ai-tool] Disabling Neovate auto-update..."
  if neovate config set autoUpdate false -g >/dev/null 2>&1; then
    echo "✓ Neovate auto-update disabled"
  else
    echo "ℹ️  Neovate auto-update could not be disabled automatically"
  fi
fi

echo "[setup-ai-tool] Setup completed successfully!"
# TODO: anthropics/skills plugin will be added once marketplace is stable
# /plugin marketplace add anthropics/skills
