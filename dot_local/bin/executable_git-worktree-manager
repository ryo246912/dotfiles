#!/bin/bash

set -euo pipefail

# 色定義
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly PURPLE='\033[0;35m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m' # No Color

# グローバル変数
WORKTREES_DATA=""
CANDIDATES_DATA=""
SELECTED_TARGET_TYPE=""
SELECTED_PATH=""
SELECTED_BRANCH=""
SELECTED_ACTION=""
SELECTED_TASK_PATH=""
SELECTED_TASK_NAME=""

# エラーハンドリング
error_exit() {
	echo "${RED}エラー: $1${NC}" >&2
	exit 1
}

# git worktreeの一覧を取得してグローバル変数に格納
get_worktrees() {
	if ! git worktree list &>/dev/null; then
		error_exit "gitリポジトリではないか、git worktreeが利用できません"
	fi

	# シンプルなパース方法を使用してグローバル変数に格納
	WORKTREES_DATA=$(git worktree list | awk '{
        path = $1
        if (NF >= 3) {
            branch = $3
            gsub(/^\[|\]$/, "", branch)
        } else {
            branch = "(detached)"
        }
        printf "%s\t%s\n", path, branch
    }')

	if [ -z "$WORKTREES_DATA" ]; then
		return 1
	fi

	return 0
}

# 候補行をグローバル変数に追加
append_candidate() {
	local candidate_line="$1"

	if [[ -n "$CANDIDATES_DATA" ]]; then
		CANDIDATES_DATA+=$'\n'
	fi

	CANDIDATES_DATA+="$candidate_line"
}

# git worktree を共通候補へ変換
append_git_candidates() {
	if ! is_git_repo; then
		return 1
	fi

	if ! get_worktrees; then
		return 1
	fi

	while IFS=$'\t' read -r path branch; do
		[[ -z "$path" ]] && continue
		append_candidate "$(printf 'git\t%s\t%s\t%s\t%s' "$branch" "$path" "$path" "$branch")"
	done <<< "$WORKTREES_DATA"

	return 0
}

# multi-worktree タスクを共通候補へ変換
append_multi_worktree_candidates() {
	local tasks
	if ! tasks=$(get_multi_worktree_tasks); then
		return 1
	fi

	while IFS=$'\t' read -r task_name group task_path repo_count devcontainer; do
		[[ -z "$task_name" ]] && continue

		local info
		local group_name="${group:-default}"
		local repo_summary="${repo_count:-0 repos}"
		info="group=${group_name} / ${repo_summary}"
		if [[ -n "${devcontainer:-}" ]]; then
			info="${info} / ${devcontainer}"
		fi
		info="${info} / ${task_path}"

		append_candidate "$(printf 'multi\t%s\t%s\t%s\t%s' "$task_name" "$task_path" "$info" "$task_name")"
	done <<< "$tasks"

	return 0
}

# git worktree / multi-worktree の共通候補を選択
select_target() {
	CANDIDATES_DATA=""
	append_git_candidates || true
	append_multi_worktree_candidates || true

	if [[ -z "$CANDIDATES_DATA" ]]; then
		if is_git_repo; then
			error_exit "git worktree も multi-worktree タスクも見つかりません"
		fi
		error_exit "multi-worktree のタスクが見つかりません（コマンドが存在しないかタスクが0件です）"
	fi

	if [[ "${DEBUG:-}" == "1" ]]; then
		echo "${PURPLE}[DEBUG] 取得した候補:${NC}" >&2
		echo "$CANDIDATES_DATA" | cat -A >&2
		echo "${PURPLE}[DEBUG] 行数: $(echo "$CANDIDATES_DATA" | wc -l)${NC}" >&2
	fi

	local selected_display
	selected_display=$(printf '%s\n' "$CANDIDATES_DATA" | fzf \
		--header="対象を選択してください (git worktree / multi-worktree)" \
		--delimiter=$'\t' \
		--with-nth=1,2,4 \
		--preview='bash -c '"'"'
kind="$1"
path="$2"

if [[ "$kind" == "git" ]]; then
	git -C "$path" log --oneline -10 2>/dev/null || echo "ログ取得エラー"
	exit 0
fi

for d in "$path"/*/; do
	[ -d "$d" ] || continue
	r=$(basename "$d")
	case "$r" in
		.*) continue ;;
	esac
	printf "▶ %s (%s)\n" "$r" "$(git -C "$d" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
	git -C "$d" log --oneline -3 2>/dev/null
	echo
done
'"'"' _ {1} {3}' \
		--preview-window="right:50%")

	if [ -z "$selected_display" ]; then
		echo "${YELLOW}選択がキャンセルされました${NC}" >&2
		return 1
	fi

	SELECTED_TARGET_TYPE=$(echo "$selected_display" | cut -f1)
	case "$SELECTED_TARGET_TYPE" in
	"git")
		SELECTED_PATH=$(echo "$selected_display" | cut -f3)
		SELECTED_BRANCH=$(echo "$selected_display" | cut -f5)
		SELECTED_TASK_PATH=""
		SELECTED_TASK_NAME=""
		;;
	"multi")
		SELECTED_TASK_PATH=$(echo "$selected_display" | cut -f3)
		SELECTED_TASK_NAME=$(echo "$selected_display" | cut -f5)
		SELECTED_PATH=""
		SELECTED_BRANCH=""
		;;
	*)
		return 1
		;;
	esac

	if [[ "${DEBUG:-}" == "1" ]]; then
		echo "${PURPLE}[DEBUG] 選択結果:${NC}" >&2
		echo "${PURPLE}[DEBUG] 種別: '$SELECTED_TARGET_TYPE'${NC}" >&2
		echo "${PURPLE}[DEBUG] git path: '$SELECTED_PATH'${NC}" >&2
		echo "${PURPLE}[DEBUG] git branch: '$SELECTED_BRANCH'${NC}" >&2
		echo "${PURPLE}[DEBUG] multi path: '$SELECTED_TASK_PATH'${NC}" >&2
		echo "${PURPLE}[DEBUG] multi task: '$SELECTED_TASK_NAME'${NC}" >&2
	fi

	return 0
}

# アクションを選択
select_action() {
	# 利用可能なアクションとその説明
	local actions="lazygit	Lazygitでリポジトリを開く
code	VS Codeでディレクトリを開く
nvim	Neovimでディレクトリを開く
czg	czgでコミットを作成
diff	git diffを表示
cd	ディレクトリに移動する（新しいシェル）"

	# fzfでアクション選択
	local selected_action_display
	selected_action_display=$(echo "$actions" | fzf \
		--header="実行するアクションを選択してください" \
		--delimiter='\t' \
		--with-nth=1,2 \
		--preview="echo 'アクション: {1}'; echo '説明: {2}'" \
		--preview-window="right:40%")

	if [ -z "$selected_action_display" ]; then
		echo "${YELLOW}アクション選択がキャンセルされました${NC}" >&2
		return 1
	fi

	# 選択されたアクションを抽出
	SELECTED_ACTION=$(echo "$selected_action_display" | awk -F'\t' '{print $1}')

	# デバッグ用出力
	if [[ "${DEBUG:-}" == "1" ]]; then
		echo "${PURPLE}[DEBUG] 選択されたアクション: '$SELECTED_ACTION'${NC}" >&2
	fi

	# 選択結果の検証
	if [ -z "$SELECTED_ACTION" ]; then
		return 1
	fi

	return 0
}

# lazygitを開く
open_lazygit() {
	local worktree_path="$1"
	local branch_name="$2"

	if [ ! -d "$worktree_path" ]; then
		error_exit "worktreeディレクトリが存在しません: $worktree_path"
	fi

	if ! command -v lazygit &>/dev/null; then
		error_exit "lazygit コマンドが見つかりません"
	fi

	# worktreeディレクトリに移動してlazygitを起動
	cd "$worktree_path" || error_exit "ディレクトリへの移動に失敗: $worktree_path"

	# lazygitを起動
	lazygit

	return 0
}

# VS Codeで開く
open_code() {
	local worktree_path="$1"
	local branch_name="$2"

	if [ ! -d "$worktree_path" ]; then
		error_exit "worktreeディレクトリが存在しません: $worktree_path"
	fi

	if ! command -v code &>/dev/null; then
		error_exit "VS Code (code コマンド) が見つかりません"
	fi

	# VS Codeでディレクトリを開く
	code "$worktree_path"

	return 0
}

# Neovimで開く
open_nvim() {
	local worktree_path="$1"
	local branch_name="$2"

	if [ ! -d "$worktree_path" ]; then
		error_exit "worktreeディレクトリが存在しません: $worktree_path"
	fi

	if ! command -v nvim &>/dev/null; then
		error_exit "Neovim (nvim コマンド) が見つかりません"
	fi

	# worktreeディレクトリに移動してneovimを起動
	cd "$worktree_path" || error_exit "ディレクトリへの移動に失敗: $worktree_path"

	# neovimを起動
	nvim .

	return 0
}

# czgでコミットを作成
open_czg() {
	local worktree_path="$1"
	local branch_name="$2"

	if [ ! -d "$worktree_path" ]; then
		error_exit "worktreeディレクトリが存在しません: $worktree_path"
	fi

	if ! command -v czg &> /dev/null; then
		error_exit "czg コマンドが見つかりません"
	fi

	# worktreeディレクトリに移動してczgを起動
	cd "$worktree_path" || error_exit "ディレクトリへの移動に失敗: $worktree_path"

	# czgを起動
	czg

	return 0
}

# git diffを表示
show_diff() {
	local worktree_path="$1"
	local branch_name="$2"

	if [ ! -d "$worktree_path" ]; then
		error_exit "worktreeディレクトリが存在しません: $worktree_path"
	fi

	# worktreeディレクトリに移動してczgを起動
	cd "$worktree_path" || error_exit "ディレクトリへの移動に失敗: $worktree_path"

	# git diffを表示
	git diff main "$branch_name" | delta --no-gitconfig

	return 0
}

# ディレクトリに移動（新しいシェル）
change_directory() {
	local worktree_path="$1"
	local branch_name="$2"

	if [ ! -d "$worktree_path" ]; then
		error_exit "worktreeディレクトリが存在しません: $worktree_path"
	fi

	# worktreeディレクトリに移動して新しいシェルを起動
	cd "$worktree_path" || error_exit "ディレクトリへの移動に失敗: $worktree_path"

  exec "$SHELL"

	return 0
}

# 選択されたアクションを実行
execute_action() {
	local worktree_path="$1"
	local branch_name="$2"
	local action="$3"

	case "$action" in
	"lazygit")
		open_lazygit "$worktree_path" "$branch_name"
		;;
	"code")
		open_code "$worktree_path" "$branch_name"
		;;
	"nvim")
		open_nvim "$worktree_path" "$branch_name"
		;;
	"czg")
		open_czg "$worktree_path" "$branch_name"
		;;
	"diff")
		show_diff "$worktree_path" "$branch_name"
		;;
	"cd")
		change_directory "$worktree_path" "$branch_name"
		;;
	*)
		error_exit "不明なアクション: $action"
		;;
	esac

	return 0
}

# 現在のディレクトリがgitリポジトリかどうかを確認
is_git_repo() {
	git rev-parse --git-dir &>/dev/null
}

# multi-worktree list の出力を取得（TSV形式）
# 出力: <task-name>\t<group>\t<path>\t<repo-count> repos\t[devcontainer]
get_multi_worktree_tasks() {
	if ! command -v multi-worktree &>/dev/null; then
		return 1
	fi
	local tasks
	tasks=$(multi-worktree list 2>/dev/null) || return 1
	[[ -z "$tasks" ]] && return 1
	echo "$tasks"
}

# multi-worktree モードで実行するコマンドを選択
select_multi_worktree_command() {
	local actions
	actions="lazygit	lazygit でリポジトリを開く
cd	シェルでディレクトリを開く
code	VS Code でルートディレクトリを開く
nvim	Neovim でルートディレクトリを開く
sync	multi-worktree sync でworktreeを同期する"

	local selected
	selected=$(echo "$actions" | fzf \
		--header="実行するコマンドを選択" \
		--delimiter=$'\t' \
		--with-nth=1,2 \
		--preview-window="hidden")

	if [[ -z "$selected" ]]; then
		echo "${YELLOW}選択がキャンセルされました${NC}" >&2
		return 1
	fi

	echo "$selected" | cut -f1
}

# タスク内の全リポジトリを tmux tiled layout で起動
open_multi_worktree_tiled() {
	local task_path="$1"
	local task_name="$2"
	local cmd="${3:-lazygit}"

	# code の場合はルートディレクトリを直接開く
	if [[ "$cmd" == "code" ]] || [[ "$cmd" == "vscode" ]]; then
		if ! command -v code &>/dev/null; then
			echo "${RED}エラー: VS Code (code コマンド) が見つかりません${NC}" >&2
			return 1
		fi
		code "$task_path"
		return 0
	fi

	# nvim の場合はルートディレクトリを直接開く
	if [[ "$cmd" == "nvim" ]]; then
		if ! command -v nvim &>/dev/null; then
			echo "${RED}エラー: Neovim (nvim コマンド) が見つかりません${NC}" >&2
			return 1
		fi
		cd "$task_path" || return 1
		nvim .
		return 0
	fi

	# sync の場合は multi-worktree sync を実行する
	if [[ "$cmd" == "sync" ]]; then
		if ! command -v multi-worktree &>/dev/null; then
			echo "${RED}エラー: multi-worktree コマンドが見つかりません${NC}" >&2
			return 1
		fi
		multi-worktree sync "$task_name"
		return 0
	fi

	# git worktree のみを対象にリポジトリ一覧を取得
	# .git ファイル（worktree）または .git ディレクトリ（通常repo）が存在するもののみ
	local repos=()
	for repo_dir in "$task_path"/*/; do
		[[ -d "$repo_dir" ]] || continue
		local repo_name
		repo_name=$(basename "$repo_dir")
		[[ "$repo_name" =~ ^\. ]] && continue
		[[ -f "$repo_dir/.git" ]] || [[ -d "$repo_dir/.git" ]] || continue
		repos+=("$repo_dir")
	done

	if [[ ${#repos[@]} -eq 0 ]]; then
		echo "${RED}エラー: タスク内にリポジトリが見つかりません: $task_path${NC}" >&2
		return 1
	fi

	# cd または lazygit の場合のみ、タスクルートディレクトリも別ペインとして追加
	if [[ "$cmd" == "cd" ]] || [[ "$cmd" == "lazygit" ]]; then
		repos+=("$task_path")
	fi

	# tmux 環境外の場合は最初のリポジトリで直接起動
	if [[ -z "${TMUX:-}" ]]; then
		echo "${YELLOW}tmux 環境ではないため、最初のリポジトリで ${cmd} を起動します${NC}" >&2
		cd "${repos[0]}" && [[ "$cmd" == "lazygit" ]] && lazygit || exec zsh
		return 0
	fi

	# ウィンドウ名（/ を - に変換）
	local window_name
	window_name="$(echo "$task_name" | tr '/' '-')"

	# 現在のセッション名を取得
	local session_name
	session_name=$(tmux display-message -p '#S')

	# 2列固定レイアウト: 左列 repos[0,2,4...] / 右列 repos[1,3,5...]
	# lazygit: zsh -f で起動後に send-keys でlazygit送信（シェル初期化スキップ）
	# cd:      zsh で起動（通常シェル、ユーザー設定を読み込む）

	local count=${#repos[@]}
	local shell_cmd
	[[ "$cmd" == "cd" ]] && shell_cmd="zsh" || shell_cmd="zsh -f"

	# 各repoのペイン起動コマンドを決定
	# lazygit モードで非gitディレクトリ（タスクルートなど）は通常のzshで起動
	local -a pane_shells=()
	for _repo in "${repos[@]}"; do
		local _d="${_repo%/}"
		if [[ "$cmd" == "lazygit" ]] && ! [[ -f "$_d/.git" ]] && ! [[ -d "$_d/.git" ]]; then
			pane_shells+=("zsh")
		else
			pane_shells+=("$shell_cmd")
		fi
	done

	# ペインIDリスト（%N形式）: pane-base-index に依存しない一意なID
	local -a pane_ids=()

	# ペイン0: 新しいウィンドウを作成し、最初のペインIDを取得
	tmux new-window -n "$window_name" -c "${repos[0]}" -t "${session_name}:" "${pane_shells[0]}"
	local win_idx
	win_idx=$(tmux display-message -t "${session_name}:${window_name}" -p '#{window_index}')
	pane_ids+=("$(tmux display-message -t "${session_name}:${win_idx}" -p '#{pane_id}')")

	if [[ "${DEBUG:-}" == "1" ]]; then
		echo "[DEBUG] session=$session_name window=$window_name win_idx=$win_idx count=$count cmd=$cmd" >&2
		echo "[DEBUG] repos: ${repos[*]}" >&2
		echo "[DEBUG] pane_shells: ${pane_shells[*]}" >&2
		echo "[DEBUG] pane_ids[0]=${pane_ids[0]}" >&2
	fi

	if [[ $count -ge 2 ]]; then
		# ペイン1: ペイン0を水平分割して右列先頭を作成
		local pid
		pid=$(tmux split-window -h -t "${pane_ids[0]}" -c "${repos[1]}" -P -F '#{pane_id}' "${pane_shells[1]}")
		pane_ids+=("$pid")
	fi

	# ペイン2以降: pane_ids[i-2] を縦分割
	# pane_ids[0]=左上, pane_ids[1]=右上, pane_ids[2]=左2行目, pane_ids[3]=右2行目 ...
	local i=2
	while [[ $i -lt $count ]]; do
		pid=$(tmux split-window -v -t "${pane_ids[$((i - 2))]}" -c "${repos[$i]}" -P -F '#{pane_id}' "${pane_shells[$i]}")
		pane_ids+=("$pid")
		i=$((i + 1))
	done

	# タイルレイアウトで均等化
	tmux select-layout -t "${session_name}:${win_idx}" tiled

	# lazygit の場合、gitディレクトリのペインのみlazygitを送信
	# 非gitディレクトリ（タスクルートなど）はshellのみ起動済み
	if [[ "$cmd" == "lazygit" ]]; then
		for idx in "${!pane_ids[@]}"; do
			local _d="${repos[$idx]%/}"
			if [[ -f "$_d/.git" ]] || [[ -d "$_d/.git" ]]; then
				tmux send-keys -t "${pane_ids[$idx]}" "lazygit" Enter
			fi
		done
	fi

	# cd の場合は各ペインにEnterを送信（zsh初期化完了後のプロンプト表示のため）
	if [[ "$cmd" == "cd" ]]; then
		for pid in "${pane_ids[@]}"; do
			tmux send-keys -t "$pid" "" Enter
		done
	fi

	# overlay セッションのクライアントが detach したとき（Ctrl+B+D 等）に
	# 作成した lazygit ウィンドウを自動で閉じる
	if tmux has-session -t overlay 2>/dev/null; then
		local win_spec="${session_name}:${win_idx}"
		tmux set-hook -a -t overlay after-client-detached \
			"kill-window -t '${win_spec}' 2>/dev/null; true"
	fi

	return 0
}

# multi-worktree 用アクション実行
execute_multi_action() {
	local task_path="$1"
	local task_name="$2"
	local action="$3"

	case "$action" in
	"lazygit" | "code" | "nvim" | "cd" | "sync")
		open_multi_worktree_tiled "$task_path" "$task_name" "$action"
		;;
	"czg" | "diff")
		error_exit "アクション '$action' は multi-worktree では未対応です"
		;;
	*)
		error_exit "不明なアクション: $action"
		;;
	esac
}

# 選択対象に応じてアクションを実行
execute_selected_target() {
	case "$SELECTED_TARGET_TYPE" in
	"git")
		execute_action "$SELECTED_PATH" "$SELECTED_BRANCH" "$SELECTED_ACTION"
		;;
	"multi")
		execute_multi_action "$SELECTED_TASK_PATH" "$SELECTED_TASK_NAME" "$SELECTED_ACTION"
		;;
	*)
		error_exit "不明な選択種別: $SELECTED_TARGET_TYPE"
		;;
	esac
}

# ヘルプを表示
show_help() {
	cat << 'EOF'
Git Worktree Manager - git worktree / multi-worktree の管理とアクション実行

使用方法:
  git-worktree-manager [オプション] [アクション]

オプション:
  --help, -h      このヘルプを表示
  --debug         デバッグモード（詳細情報を表示）

アクション:
  lazygit         Lazygitでリポジトリを開く
  code            VS Codeでディレクトリを開く
  nvim            Neovimでディレクトリを開く
  czg             czgでコミットを作成
  diff            git diffを表示
  cd              ディレクトリに移動する（新しいシェル）

補足:
  - git 管理下でも git worktree と multi-worktree タスクをまとめて選択できます
  - 直接アクション指定で multi-worktree に適用できるのは lazygit / code / nvim / cd のみです
  - multi-worktree の sync はインタラクティブ選択時のみ利用できます

実行例:
  # インタラクティブ選択（対象選択 → アクション選択）
  git-worktree-manager

  # 直接アクション指定（対象選択のみ）
  git-worktree-manager lazygit
  git-worktree-manager code
  git-worktree-manager nvim
  git-worktree-manager czg
  git-worktree-manager diff
  git-worktree-manager cd

  # その他
  git-worktree-manager --debug   # デバッグモード

EOF
}

# メイン処理
main() {
	# ヘルプの場合
	if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
		show_help
		return 0
	fi

	# デバッグモードの場合
	if [[ "${1:-}" == "--debug" ]]; then
		export DEBUG=1
		shift
	fi

	# 直接アクション指定の場合
	if [[ "${1:-}" =~ ^(lazygit|code|nvim|czg|diff|cd)$ ]]; then
		SELECTED_ACTION="$1"
		shift
	fi

	# 対象選択
	if ! select_target; then
		exit 0
	fi

	# アクション選択（直接指定されていない場合のみ）
	if [ -z "$SELECTED_ACTION" ]; then
		if [[ "$SELECTED_TARGET_TYPE" == "multi" ]]; then
			SELECTED_ACTION=$(select_multi_worktree_command) || exit 0
		else
			if ! select_action; then
				exit 0
			fi
		fi
	fi

	# デバッグ情報
	if [[ "${DEBUG:-}" == "1" ]]; then
		echo "${PURPLE}[DEBUG] 最終結果:${NC}"
		echo "${PURPLE}[DEBUG] target_type: '$SELECTED_TARGET_TYPE'${NC}"
		echo "${PURPLE}[DEBUG] worktree_path: '$SELECTED_PATH'${NC}"
		echo "${PURPLE}[DEBUG] branch_name: '$SELECTED_BRANCH'${NC}"
		echo "${PURPLE}[DEBUG] task_path: '$SELECTED_TASK_PATH'${NC}"
		echo "${PURPLE}[DEBUG] task_name: '$SELECTED_TASK_NAME'${NC}"
		echo "${PURPLE}[DEBUG] action: '$SELECTED_ACTION'${NC}"
	fi

	# 選択結果の最終検証
	case "$SELECTED_TARGET_TYPE" in
	"git")
		if [ -z "$SELECTED_PATH" ] || [ -z "$SELECTED_BRANCH" ] || [ -z "$SELECTED_ACTION" ]; then
			error_exit "選択に失敗しました (type='$SELECTED_TARGET_TYPE', path='$SELECTED_PATH', branch='$SELECTED_BRANCH', action='$SELECTED_ACTION')"
		fi
		;;
	"multi")
		if [ -z "$SELECTED_TASK_PATH" ] || [ -z "$SELECTED_TASK_NAME" ] || [ -z "$SELECTED_ACTION" ]; then
			error_exit "選択に失敗しました (type='$SELECTED_TARGET_TYPE', task_path='$SELECTED_TASK_PATH', task_name='$SELECTED_TASK_NAME', action='$SELECTED_ACTION')"
		fi
		;;
	*)
		error_exit "選択に失敗しました (type='$SELECTED_TARGET_TYPE', action='$SELECTED_ACTION')"
		;;
	esac

	# アクション実行
	execute_selected_target

	return 0
}

# スクリプト実行
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
fi
