#!/usr/bin/env bun

import { spawnSync } from "node:child_process"

type FieldValue = string | number | boolean

type CommandOptions = {
  inputText?: string
  check?: boolean
}

type GhApiOptions = {
  method?: string
  fields?: Record<string, FieldValue>
  inputJson?: string
  check?: boolean
}

type RepositoryInfo = {
  private?: boolean
}

type RepositoryTarget = {
  owner: string
  repoName: string
  repoPath: string
  source: "argument" | "current git repository"
}

type RulesetSummary = {
  id?: number
  name?: string
}

const REPOSITORY_SETTINGS = {
  allow_squash_merge: true,
  allow_merge_commit: true,
  allow_rebase_merge: false,
  allow_update_branch: true,
  delete_branch_on_merge: true,
  has_issues: true,
} as const

const RULESET_CONFIG = {
  name: "main",
  target: "branch",
  enforcement: "active",
  default_branch_ref: "~DEFAULT_BRANCH",
  bypass_actors: [
    {
      actor_id: 5,
      actor_type: "RepositoryRole",
      bypass_mode: "pull_request",
    },
  ],
  pull_request: {
    dismiss_stale_reviews_on_push: true,
    require_code_owner_review: false,
    require_last_push_approval: true,
    required_approving_review_count: 1,
    required_review_thread_resolution: false,
    allowed_merge_methods: ["merge", "squash"],
  },
  required_status_check_contexts: [] as string[],
} as const

function runCommand(
  command: string[],
  { inputText, check = true }: CommandOptions = {},
) {
  const result = spawnSync(command[0], command.slice(1), {
    input: inputText,
    encoding: "utf-8",
  })

  if (result.error && check) {
    throw result.error
  }

  if (check && result.status !== 0) {
    const message =
      result.stderr.trim() || result.stdout.trim() || "command failed"
    throw new Error(message)
  }

  return result
}

function ghApi(
  endpoint: string,
  { method, fields, inputJson, check = true }: GhApiOptions = {},
) {
  const command = ["gh", "api", endpoint]

  if (method) {
    command.push("--method", method)
  }

  if (fields) {
    for (const [name, value] of Object.entries(fields)) {
      command.push("--field", `${name}=${String(value)}`)
    }
  }

  if (inputJson !== undefined) {
    command.push("--input", "-")
  }

  return runCommand(command, { inputText: inputJson, check })
}

function ghApiJson<T>(
  endpoint: string,
  { method, fields, inputJson, check = true }: GhApiOptions = {},
) {
  const result = ghApi(endpoint, { method, fields, inputJson, check })
  const output = result.stdout.trim()
  return output ? (JSON.parse(output) as T) : null
}

function buildRulesetPayload() {
  const rules = [
    { type: "creation", parameters: {} },
    { type: "deletion", parameters: {} },
    { type: "non_fast_forward" },
    { type: "required_linear_history" },
    { type: "required_signatures" },
    {
      type: "pull_request",
      parameters: RULESET_CONFIG.pull_request,
    },
  ]

  if (RULESET_CONFIG.required_status_check_contexts.length > 0) {
    rules.push({
      type: "required_status_checks",
      parameters: {
        do_not_enforce_on_create: false,
        required_status_checks: RULESET_CONFIG.required_status_check_contexts.map(
          (context) => ({ context }),
        ),
        strict_required_status_checks_policy: true,
      },
    })
  }

  return {
    name: RULESET_CONFIG.name,
    target: RULESET_CONFIG.target,
    enforcement: RULESET_CONFIG.enforcement,
    bypass_actors: RULESET_CONFIG.bypass_actors,
    conditions: {
      ref_name: {
        include: [RULESET_CONFIG.default_branch_ref],
        exclude: [],
      },
    },
    rules,
  }
}

function parseGitHubRepoPath(remoteUrl: string) {
  const match = remoteUrl
    .trim()
    .match(
      /^(?:https:\/\/github\.com\/|git@github\.com:|ssh:\/\/git@github\.com\/)([^/]+)\/([^/]+?)(?:\.git)?\/?$/,
    )

  if (!match) {
    return null
  }

  return `${match[1]}/${match[2]}`
}

function resolveRepoFromCurrentDirectory(): RepositoryTarget {
  const insideWorktree = runCommand(
    ["git", "rev-parse", "--is-inside-work-tree"],
    { check: false },
  )

  if (insideWorktree.status !== 0 || insideWorktree.stdout.trim() !== "true") {
    console.error(
      "エラー: 引数が未指定で、カレントディレクトリは git repository として判定できませんでした。",
    )
    showHelp()
    process.exit(1)
  }

  const remoteUrlResult = runCommand(
    ["git", "config", "--get", "remote.origin.url"],
    {
      check: false,
    },
  )
  const remoteUrl = remoteUrlResult.stdout.trim()

  if (remoteUrlResult.status !== 0 || remoteUrl === "") {
    console.error(
      "エラー: 引数が未指定ですが、current git repository に `origin` remote がありません。",
    )
    showHelp()
    process.exit(1)
  }

  const repoPath = parseGitHubRepoPath(remoteUrl)

  if (!repoPath) {
    console.error(
      `エラー: origin remote '${remoteUrl}' から GitHub の owner/repo を解決できません。`,
    )
    showHelp()
    process.exit(1)
  }

  const [owner, repoName] = repoPath.split("/", 2)

  return {
    owner,
    repoName,
    repoPath,
    source: "current git repository",
  }
}

function showHelp() {
  const scriptName = process.argv[1]

  console.log(`使用方法: ${scriptName} [owner/repository_name]

リポジトリと ruleset を設定します。

引数:
  owner/repository_name     省略可能。未指定時は current git repository の \`origin\` から解決

設定値を変更したい場合は、スクリプト内の定数オブジェクトを編集してください。

リポジトリ設定（固定）:
  スカッシュマージ許可: ${String(REPOSITORY_SETTINGS.allow_squash_merge)}
  マージコミット許可: ${String(REPOSITORY_SETTINGS.allow_merge_commit)}
  リベースマージ許可: ${String(REPOSITORY_SETTINGS.allow_rebase_merge)}
  ブランチ更新許可: ${String(REPOSITORY_SETTINGS.allow_update_branch)}
  マージ後ブランチ削除: ${String(REPOSITORY_SETTINGS.delete_branch_on_merge)}
  Issues機能: ${String(REPOSITORY_SETTINGS.has_issues)}

Dependabot セキュリティ設定（固定）:
  Dependabot alerts: enabled
  Dependabot security updates: enabled
  Dependency graph: enabled
  Dependabot version updates: 状態確認のみ（手動で無効化が必要）

ruleset 設定（固定）:
  ルールセット名: ${RULESET_CONFIG.name}
  実行モード: ${RULESET_CONFIG.enforcement}
  対象ブランチ: ${RULESET_CONFIG.default_branch_ref}
  classic branch protection: 扱わない
  bypass actor: admin role（pull_request のみ）
  削除防止: true
  更新許可: false（PR 経由のみ）
  必要承認数: ${RULESET_CONFIG.pull_request.required_approving_review_count}
  最新プッシュ承認要求: ${String(RULESET_CONFIG.pull_request.require_last_push_approval)}
  古いレビュー却下: ${String(RULESET_CONFIG.pull_request.dismiss_stale_reviews_on_push)}
  Code Owner review 要求: ${String(RULESET_CONFIG.pull_request.require_code_owner_review)}
  会話解決要求: ${String(RULESET_CONFIG.pull_request.required_review_thread_resolution)}
  許可マージ方法: ${RULESET_CONFIG.pull_request.allowed_merge_methods.join(", ")}
  required status checks: ${
    RULESET_CONFIG.required_status_check_contexts.length > 0
      ? RULESET_CONFIG.required_status_check_contexts.join(", ")
      : "未設定"
  }

例:
  ${scriptName}
  ${scriptName} username/my-repo
  ${scriptName} organization/another-repo`)
}

function parseArgs(argv: string[]): RepositoryTarget {
  if (argv.length === 0) {
    return resolveRepoFromCurrentDirectory()
  }

  if (argv[0] === "-h" || argv[0] === "--help") {
    showHelp()
    process.exit(0)
  }

  if (argv.length > 1) {
    console.error(
      `エラー: 余分な引数が指定されています: ${argv.slice(1).join(" ")}`,
    )
    console.error(
      "このスクリプトは owner/repository 形式の引数のみを受け取ります。",
    )
    showHelp()
    process.exit(1)
  }

  const repoFullName = argv[0]

  if (!/^[^/]+\/[^/]+$/.test(repoFullName)) {
    console.error(
      "エラー: リポジトリ名は 'owner/repository' の形式で指定してください。",
    )
    console.error("例: username/my-repo")
    showHelp()
    process.exit(1)
  }

  const [owner, repoName] = repoFullName.split("/", 2)

  if (!owner || !repoName) {
    console.error("エラー: owner または repository 名が空です。")
    console.error("正しい形式: owner/repository")
    showHelp()
    process.exit(1)
  }

  return {
    owner,
    repoName,
    repoPath: `${owner}/${repoName}`,
    source: "argument",
  }
}

function ensureRepositoryExists(repoPath: string) {
  const result = ghApi(`repos/${repoPath}`, { check: false })

  if (result.status !== 0) {
    console.error(`エラー: リポジトリ '${repoPath}' が見つかりません。`)
    console.error("リポジトリが存在することを確認してください。")
    process.exit(1)
  }

  const repoInfo = JSON.parse(result.stdout) as RepositoryInfo
  const isPrivate = Boolean(repoInfo.private)

  if (isPrivate) {
    console.log(
      "注意: プライベートリポジトリです。一部の機能（ruleset）は GitHub Pro が必要なためスキップされます。",
    )
  }

  return isPrivate
}

function updateRepositorySettings(repoPath: string) {
  console.log("リポジトリ設定を更新中...")

  const result = ghApi(`repos/${repoPath}`, {
    method: "PATCH",
    fields: REPOSITORY_SETTINGS,
    check: false,
  })

  if (result.status !== 0) {
    console.log("注意: 一部の設定更新に失敗しました。権限を確認してください。")
  }

  console.log(`リポジトリ '${repoPath}' の設定を更新しました。`)
  console.log("更新された設定:")
  console.log(
    `  - スカッシュマージ許可: ${String(REPOSITORY_SETTINGS.allow_squash_merge)}`,
  )
  console.log(
    `  - マージコミット許可: ${String(REPOSITORY_SETTINGS.allow_merge_commit)}`,
  )
  console.log(
    `  - リベースマージ許可: ${String(REPOSITORY_SETTINGS.allow_rebase_merge)}`,
  )
  console.log(
    `  - ブランチ更新許可: ${String(REPOSITORY_SETTINGS.allow_update_branch)}`,
  )
  console.log(
    `  - マージ後ブランチ削除: ${String(REPOSITORY_SETTINGS.delete_branch_on_merge)}`,
  )
  console.log(`  - Issues機能: ${String(REPOSITORY_SETTINGS.has_issues)}`)
}

function getExistingRulesetId(repoPath: string) {
  const rulesets = ghApiJson<RulesetSummary[]>(`repos/${repoPath}/rulesets`)

  if (!Array.isArray(rulesets)) {
    return null
  }

  const current = rulesets.find(
    (ruleset) => ruleset.name === RULESET_CONFIG.name,
  )

  return current?.id ?? null
}

function createRuleset(repoPath: string) {
  console.log(`ルールセット '${RULESET_CONFIG.name}' を作成しています...`)
  ghApi(`repos/${repoPath}/rulesets`, {
    method: "POST",
    inputJson: JSON.stringify(buildRulesetPayload()),
  })
  console.log(`ルールセット '${RULESET_CONFIG.name}' を作成しました。`)
}

function updateRuleset(repoPath: string, rulesetId: number) {
  console.log(
    `ルールセット '${RULESET_CONFIG.name}' (ID: ${rulesetId}) を更新しています...`,
  )
  ghApi(`repos/${repoPath}/rulesets/${rulesetId}`, {
    method: "PUT",
    inputJson: JSON.stringify(buildRulesetPayload()),
  })
  console.log(`ルールセット '${RULESET_CONFIG.name}' を更新しました。`)
}

function setupRuleset(repoPath: string) {
  const existingRulesetId = getExistingRulesetId(repoPath)

  if (existingRulesetId !== null) {
    console.log("ルールセットが既に存在します。更新します。")
    updateRuleset(repoPath, existingRulesetId)
  } else {
    createRuleset(repoPath)
  }

  console.log("ルールセット設定が完了しました。")
  console.log("設定されたルールセット:")
  console.log(`  - ルールセット名: ${RULESET_CONFIG.name}`)
  console.log(`  - 実行モード: ${RULESET_CONFIG.enforcement}`)
  console.log(`  - 対象ブランチ: ${RULESET_CONFIG.default_branch_ref}`)
  console.log("  - bypass actor: admin role (pull_request only)")
  console.log("  - 削除防止: true")
  console.log("  - 更新許可: false (PR 経由のみ)")
  console.log(
    `  - 必要承認数: ${RULESET_CONFIG.pull_request.required_approving_review_count}`,
  )
  console.log(
    `  - 最新プッシュ承認要求: ${String(RULESET_CONFIG.pull_request.require_last_push_approval)}`,
  )
  console.log(
    `  - 古いレビュー却下: ${String(RULESET_CONFIG.pull_request.dismiss_stale_reviews_on_push)}`,
  )
  console.log(
    `  - Code Owner review要求: ${String(RULESET_CONFIG.pull_request.require_code_owner_review)}`,
  )
  console.log(
    `  - 会話解決要求: ${String(RULESET_CONFIG.pull_request.required_review_thread_resolution)}`,
  )
  console.log(
    `  - 許可マージ方法: ${RULESET_CONFIG.pull_request.allowed_merge_methods.join(", ")}`,
  )

  if (RULESET_CONFIG.required_status_check_contexts.length > 0) {
    console.log(
      `  - required status checks: ${RULESET_CONFIG.required_status_check_contexts.join(", ")}`,
    )
  } else {
    console.log("  - required status checks: 未設定")
  }
}

function setupNotifications(repoPath: string) {
  const result = ghApi(`repos/${repoPath}/subscription`, {
    method: "PUT",
    fields: { ignored: true },
    check: false,
  })

  if (result.status === 0) {
    console.log(`リポジトリ '${repoPath}' の通知を Ignore に設定しました。`)
  } else {
    console.error("注意: 通知設定に失敗しました。権限を確認してください。")
  }
}

function setupDependabotSecurity(repoPath: string) {
  console.log("Dependabot セキュリティ機能を設定中...")

  let success = true

  if (
    ghApi(`repos/${repoPath}/vulnerability-alerts`, {
      method: "PUT",
      check: false,
    }).status === 0
  ) {
    console.log("  - Dependabot alerts を有効化しました")
  } else {
    console.error("  - Dependabot alerts の有効化に失敗しました")
    success = false
  }

  if (
    ghApi(`repos/${repoPath}/automated-security-fixes`, {
      method: "PUT",
      check: false,
    }).status === 0
  ) {
    console.log("  - Dependabot security updates を有効化しました")
  } else {
    console.error("  - Dependabot security updates の有効化に失敗しました")
    success = false
  }

  if (
    ghApi(`repos/${repoPath}`, {
      method: "PATCH",
      fields: { has_vulnerability_alerts: true },
      check: false,
    }).status === 0
  ) {
    console.log("  - Dependency graph を有効化しました")
  } else {
    console.error("  - Dependency graph の有効化に失敗しました")
    success = false
  }

  console.log("  - Dependabot version updates の状態を確認中...")

  if (
    ghApi(`repos/${repoPath}/contents/.github/dependabot.yml`, {
      check: false,
    }).status === 0
  ) {
    console.log(
      "  - Dependabot version updates が有効です（.github/dependabot.yml が存在）",
    )
    console.log(
      "    無効化する場合は手動で .github/dependabot.yml を削除してください",
    )
  } else {
    console.log("  - Dependabot version updates は無効です（.github/dependabot.yml なし）")
  }

  if (success) {
    console.log("Dependabot セキュリティ機能の設定が完了しました。")
  } else {
    console.error(
      "注意: 一部のセキュリティ機能の設定に失敗しました。権限を確認してください。",
    )
  }
}

function main() {
  const { repoPath, source } = parseArgs(process.argv.slice(2))

  console.log("=== GitHub リポジトリと ruleset の設定を開始します ===")
  console.log(`リポジトリ: ${repoPath}`)
  console.log(`解決元: ${source === "argument" ? "引数" : "current git repository"}`)
  console.log("")

  const isPrivate = ensureRepositoryExists(repoPath)

  console.log("=== ステップ 1: リポジトリ設定の更新 ===")
  updateRepositorySettings(repoPath)
  console.log("")

  console.log("=== ステップ 2: ruleset の設定 ===")
  if (isPrivate) {
    console.log(
      "プライベートリポジトリのため、ruleset 設定をスキップします（GitHub Pro が必要）。",
    )
  } else {
    setupRuleset(repoPath)
  }
  console.log("")

  console.log("=== ステップ 3: Dependabot セキュリティ機能の有効化 ===")
  setupDependabotSecurity(repoPath)
  console.log("")

  console.log("=== ステップ 4: 通知設定 ===")
  setupNotifications(repoPath)

  console.log("=== 完了: すべての設定が完了しました ===")
}

main()
