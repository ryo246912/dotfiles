#!/bin/bash

# GitHub リポジトリの設定更新とルールセット作成を行う統合スクリプト
# 使用方法: setup-github <owner/repository_name>

set -euo pipefail

# 固定値設定
REPO_NAME=""
OWNER=""
REPO_FULL_NAME=""
IS_PRIVATE=""
DEFAULT_BRANCH=""

# リポジトリ設定
ALLOW_SQUASH_MERGE="true"
ALLOW_MERGE_COMMIT="true"

# ブランチプロテクション設定
ENFORCE_ADMINS="false"
REQUIRED_CONVERSATION_RESOLUTION="false"

# ルールセット設定
RULESET_NAME="main"
ENFORCEMENT="active"
REF_INCLUDE=("~DEFAULT_BRANCH")
REQUIRED_APPROVING_REVIEW_COUNT="1"
REQUIRE_LAST_PUSH_APPROVAL="true"
DISMISS_STALE_REVIEWS="true"
REQUIRE_CODE_OWNER_REVIEW="false"
REQUIRED_REVIEW_THREAD_RESOLUTION="false"
ALLOWED_MERGE_METHODS=("merge" "squash")
REQUIRED_STATUS_CHECK_CONTEXTS=()
# GitHub の RepositoryRole で admin を表す固定 ID
BYPASS_REPOSITORY_ROLE_IDS=("5")

# JSON文字列のエスケープ
escape_json_string() {
    local value="$1"
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    printf '%s' "$value"
}

# 文字列配列をJSON配列に変換
strings_to_json() {
    local items=("$@")
    local json="["
    local index

    for index in "${!items[@]}"; do
        local escaped
        escaped=$(escape_json_string "${items[$index]}")
        json="${json}\"${escaped}\""
        if [[ $index -lt $((${#items[@]} - 1)) ]]; then
            json="${json},"
        fi
    done

    json="${json}]"
    echo "$json"
}

# required status checks配列をJSON配列に変換
status_checks_to_json() {
    local contexts=("$@")
    local json="["
    local index

    for index in "${!contexts[@]}"; do
        local escaped
        escaped=$(escape_json_string "${contexts[$index]}")
        json="${json}{\"context\":\"${escaped}\"}"
        if [[ $index -lt $((${#contexts[@]} - 1)) ]]; then
            json="${json},"
        fi
    done

    json="${json}]"
    echo "$json"
}

# bypass actor配列をJSON配列に変換
build_bypass_actors_json() {
    local role_ids=("$@")
    local json="["
    local index

    for index in "${!role_ids[@]}"; do
        json="${json}{\"actor_id\":${role_ids[$index]},\"actor_type\":\"RepositoryRole\",\"bypass_mode\":\"pull_request\"}"
        if [[ $index -lt $((${#role_ids[@]} - 1)) ]]; then
            json="${json},"
        fi
    done

    json="${json}]"
    echo "$json"
}

# optionalなrequired status checksルールを構築
build_required_status_checks_rule_json() {
    if [[ ${#REQUIRED_STATUS_CHECK_CONTEXTS[@]} -eq 0 ]]; then
        echo ""
        return
    fi

    local required_status_checks_json
    required_status_checks_json=$(status_checks_to_json "${REQUIRED_STATUS_CHECK_CONTEXTS[@]}")

    cat <<EOF
,
    { "type": "required_status_checks",
      "parameters": {
        "do_not_enforce_on_create": false,
        "required_status_checks": $required_status_checks_json,
        "strict_required_status_checks_policy": true
      }
    }
EOF
}

# ルールセットJSON構築共通関数
build_ruleset_json() {
    local refs_json
    refs_json=$(refs_to_json "${REF_INCLUDE[@]}")

    local last_push_bool
    last_push_bool=$(bool_to_json "$REQUIRE_LAST_PUSH_APPROVAL")

    local stale_reviews_bool
    stale_reviews_bool=$(bool_to_json "$DISMISS_STALE_REVIEWS")

    local code_owner_review_bool
    code_owner_review_bool=$(bool_to_json "$REQUIRE_CODE_OWNER_REVIEW")

    local review_thread_resolution_bool
    review_thread_resolution_bool=$(bool_to_json "$REQUIRED_REVIEW_THREAD_RESOLUTION")

    local allowed_merge_methods_json
    allowed_merge_methods_json=$(strings_to_json "${ALLOWED_MERGE_METHODS[@]}")

    local bypass_actors_json
    bypass_actors_json=$(build_bypass_actors_json "${BYPASS_REPOSITORY_ROLE_IDS[@]}")

    local status_checks_rule_json
    status_checks_rule_json=$(build_required_status_checks_rule_json)

    cat <<EOF | grep -v '#'
{
  "name": "$RULESET_NAME",
  "target": "branch",
  "enforcement": "$ENFORCEMENT",
  "bypass_actors": $bypass_actors_json,
  "conditions": {
    "ref_name": {
      "include": $refs_json,
      "exclude": []
    }
  },
  "rules": [
    # Restrict creations
    { "type": "creation", "parameters": {} },
    # Restrict deletions
    { "type": "deletion", "parameters": {} },
    # Require linear history
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    # Require signed commits
    { "type": "required_signatures" },
    # Require a pull request before merging
    { "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": $stale_reviews_bool,
        "require_code_owner_review": $code_owner_review_bool,
        "require_last_push_approval": $last_push_bool,
        "required_approving_review_count": $REQUIRED_APPROVING_REVIEW_COUNT,
        "required_review_thread_resolution": $review_thread_resolution_bool,
        "allowed_merge_methods": $allowed_merge_methods_json
      }
    }$status_checks_rule_json
  ]
}
EOF
}

# ブランチプロテクションJSON構築共通関数
build_branch_protection_json() {
    local last_push_bool
    last_push_bool=$(bool_to_json "$REQUIRE_LAST_PUSH_APPROVAL")

    local stale_reviews_bool
    stale_reviews_bool=$(bool_to_json "$DISMISS_STALE_REVIEWS")

    local code_owner_review_bool
    code_owner_review_bool=$(bool_to_json "$REQUIRE_CODE_OWNER_REVIEW")

    local conversation_resolution_bool
    conversation_resolution_bool=$(bool_to_json "$REQUIRED_CONVERSATION_RESOLUTION")

    local enforce_admins_bool
    enforce_admins_bool=$(bool_to_json "$ENFORCE_ADMINS")

    cat <<EOF
{
  "required_status_checks": {
    "strict": true,
    "checks": []
  },
  "enforce_admins": $enforce_admins_bool,
  "required_pull_request_reviews": {
    "dismiss_stale_reviews": $stale_reviews_bool,
    "require_code_owner_reviews": $code_owner_review_bool,
    "require_last_push_approval": $last_push_bool,
    "required_approving_review_count": $REQUIRED_APPROVING_REVIEW_COUNT
  },
  "restrictions": null,
  "required_linear_history": false,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "block_creations": false,
  "required_conversation_resolution": $conversation_resolution_bool,
  "lock_branch": false,
  "allow_fork_syncing": false
}
EOF
}

# ヘルプメッセージ
show_help() {
    cat << EOF
使用方法: $0 <owner/repository_name>

リポジトリとルールセットを設定します。

必須引数:
  owner/repository_name     設定を更新するリポジトリ（owner/repo形式）

設定値を変更したい場合は、スクリプト内の設定値を編集してください。

リポジトリ設定（固定）:
  スカッシュマージ許可: true
  マージコミット許可: true
  リベースマージ許可: false
  ブランチ更新許可: true
  マージ後ブランチ削除: true
  Issues機能: true

ブランチプロテクション設定（固定）:
  対象ブランチ: デフォルトブランチ
  admin適用: false（adminはclassic branch protectionをバイパス）
  必要承認数: 1
  最新プッシュ承認要求: true
  古いレビュー却下: true
  Code Owner review要求: false
  会話解決要求: false

Dependabotセキュリティ設定（固定）:
  Dependabot alerts: enabled
  Dependabot security updates: enabled
  Dependency graph: enabled
  Dependabot version updates: 状態確認のみ（手動で無効化が必要）

ルールセット設定（固定）:
  ルールセット名: main
  実行モード: active
  対象ブランチ: ~DEFAULT_BRANCH
  bypass actor: admin role（pull_requestのみ）
  削除防止: true
  更新許可: false（PR経由のみ）
  必要承認数: 1
  最新プッシュ承認要求: true
  古いレビュー却下: true
  Code Owner review要求: false
  会話解決要求: false
  許可マージ方法: merge, squash
  required status checks: 既定では未設定

例:
  $0 username/my-repo
  $0 organization/another-repo

EOF
}

# 引数解析
parse_args() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 1
    fi

    # ヘルプオプションの確認
    if [[ "$1" == "--help" || "$1" == "-h" ]]; then
        show_help
        exit 0
    fi

    REPO_FULL_NAME="$1"

    # 2番目以降の引数があった場合はエラー
    if [[ $# -gt 1 ]]; then
        echo "エラー: 余分な引数が指定されています: ${@:2}" >&2
        echo "このスクリプトはowner/repository形式の引数のみを受け取ります。" >&2
        show_help
        exit 1
    fi

    # owner/repository形式の検証と分割
    if [[ ! "$REPO_FULL_NAME" =~ ^[^/]+/[^/]+$ ]]; then
        echo "エラー: リポジトリ名は 'owner/repository' の形式で指定してください。" >&2
        echo "例: username/my-repo" >&2
        show_help
        exit 1
    fi

    # ownerとrepository名を分割
    OWNER="${REPO_FULL_NAME%%/*}"
    REPO_NAME="${REPO_FULL_NAME##*/}"

    # 空の値をチェック
    if [[ -z "$OWNER" || -z "$REPO_NAME" ]]; then
        echo "エラー: owner または repository 名が空です。" >&2
        echo "正しい形式: owner/repository" >&2
        show_help
        exit 1
    fi
}

# リポジトリの存在確認（必須）
ensure_repository_exists() {
    local repo_path="$OWNER/$REPO_NAME"
    if ! gh repo view "$repo_path" &>/dev/null; then
        echo "エラー: リポジトリ '$repo_path' が見つかりません。" >&2
        echo "リポジトリが存在することを確認してください。" >&2
        exit 1
    fi

    # プライベートリポジトリかどうかを判定
    IS_PRIVATE=$(gh api "repos/$repo_path" --jq '.private' 2>/dev/null || echo "false")
    DEFAULT_BRANCH=$(gh api "repos/$repo_path" --jq '.default_branch' 2>/dev/null || echo "")

    if [[ -z "$DEFAULT_BRANCH" || "$DEFAULT_BRANCH" == "null" ]]; then
        echo "エラー: リポジトリ '$repo_path' のデフォルトブランチを取得できません。" >&2
        exit 1
    fi

    if [ "$IS_PRIVATE" = "true" ]; then
        echo "注意: プライベートリポジトリです。一部の機能（ルールセット）はGitHub Proが必要なためスキップされます。"
    fi
}

# リポジトリ設定更新
update_repository_settings() {
    local repo_path="$OWNER/$REPO_NAME"

    # マージ設定とその他の設定をAPI経由で更新
    echo "リポジトリ設定を更新中..."
    gh api "repos/$repo_path" --method PATCH \
        --field allow_squash_merge="$ALLOW_SQUASH_MERGE" \
        --field allow_merge_commit="$ALLOW_MERGE_COMMIT" \
        --field allow_rebase_merge=false \
        --field allow_update_branch=true \
        --field delete_branch_on_merge=true \
        --field has_issues=true \
        > /dev/null \
        2>/dev/null || echo "注意: 一部の設定更新に失敗しました。権限を確認してください。"

    echo "リポジトリ '$repo_path' の設定を更新しました。"
    echo "更新された設定:"
    echo "  - スカッシュマージ許可: $ALLOW_SQUASH_MERGE"
    echo "  - マージコミット許可: $ALLOW_MERGE_COMMIT"
    echo "  - リベースマージ許可: false"
    echo "  - ブランチ更新許可: true"
    echo "  - マージ後ブランチ削除: true"
    echo "  - Issues機能: true"
}

# デフォルトブランチのプロテクション設定更新
update_branch_protection() {
    local repo_path="$OWNER/$REPO_NAME"
    echo "デフォルトブランチ '$DEFAULT_BRANCH' のブランチプロテクションを更新中..."

    local branch_protection_json
    branch_protection_json=$(build_branch_protection_json)

    gh api "repos/$repo_path/branches/$DEFAULT_BRANCH/protection" \
        --method PUT \
        --input - > /dev/null <<< "$branch_protection_json"

    echo "デフォルトブランチ '$DEFAULT_BRANCH' のブランチプロテクションを更新しました。"
    echo "更新された設定:"
    echo "  - admin適用: $ENFORCE_ADMINS"
    echo "  - 必要承認数: $REQUIRED_APPROVING_REVIEW_COUNT"
    echo "  - 最新プッシュ承認要求: $REQUIRE_LAST_PUSH_APPROVAL"
    echo "  - 古いレビュー却下: $DISMISS_STALE_REVIEWS"
    echo "  - Code Owner review要求: $REQUIRE_CODE_OWNER_REVIEW"
    echo "  - 会話解決要求: $REQUIRED_CONVERSATION_RESOLUTION"
}

# 真偽値の変換
bool_to_json() {
    case "$1" in
        true|True|TRUE) echo "true" ;;
        false|False|FALSE) echo "false" ;;
        *) echo "$1" ;;
    esac
}

# ref_include配列をJSON配列に変換
refs_to_json() {
    local refs=("$@")
    local json="["
    for i in "${!refs[@]}"; do
        json="$json\"${refs[i]}\""
        if [[ $i -lt $((${#refs[@]} - 1)) ]]; then
            json="$json,"
        fi
    done
    json="$json]"
    echo "$json"
}

# 既存ルールセットの確認
get_existing_ruleset_id() {
    local repo_path="$OWNER/$REPO_NAME"
    local ruleset_id

    ruleset_id=$(gh api "repos/$repo_path/rulesets" --jq ".[] | select(.name == \"$RULESET_NAME\") | .id" 2>/dev/null || echo "")
    echo "$ruleset_id"
}

# ルールセット作成
create_ruleset() {
    local repo_path="$OWNER/$REPO_NAME"
    echo "ルールセット '$RULESET_NAME' を作成しています..."

    local ruleset_json
    ruleset_json=$(build_ruleset_json)

    gh api "repos/$repo_path/rulesets" \
        --method POST \
        --input - <<< "$ruleset_json" \
        --jq '.id' > /dev/null

    echo "ルールセット '$RULESET_NAME' を作成しました。"
}

# ルールセット更新
update_ruleset() {
    local repo_path="$OWNER/$REPO_NAME"
    local ruleset_id="$1"
    echo "ルールセット '$RULESET_NAME' (ID: $ruleset_id) を更新しています..."

    local ruleset_json
    ruleset_json=$(build_ruleset_json)

    gh api "repos/$repo_path/rulesets/$ruleset_id" \
        --method PUT \
        --input - <<< "$ruleset_json" \
        --jq '.id' > /dev/null

    echo "ルールセット '$RULESET_NAME' を更新しました。"
}

# ルールセット設定処理
setup_ruleset() {
    local repo_path="$OWNER/$REPO_NAME"

    # 既存ルールセットの確認
    local existing_ruleset_id
    existing_ruleset_id=$(get_existing_ruleset_id)

    if [[ -n "$existing_ruleset_id" ]]; then
        echo "ルールセットが既に存在します。更新します。"
        update_ruleset "$existing_ruleset_id"
    else
        create_ruleset
    fi

    echo "ルールセット設定が完了しました。"
    echo "設定されたルールセット:"
    echo "  - ルールセット名: $RULESET_NAME"
    echo "  - 実行モード: $ENFORCEMENT"
    echo "  - 対象ブランチ: ${REF_INCLUDE[*]}"
    echo "  - bypass actor: admin role (pull_request only)"
    echo "  - 削除防止: true"
    echo "  - 更新許可: false (PR経由のみ)"
    echo "  - 必要承認数: $REQUIRED_APPROVING_REVIEW_COUNT"
    echo "  - 最新プッシュ承認要求: $REQUIRE_LAST_PUSH_APPROVAL"
    echo "  - 古いレビュー却下: $DISMISS_STALE_REVIEWS"
    echo "  - Code Owner review要求: $REQUIRE_CODE_OWNER_REVIEW"
    echo "  - 会話解決要求: $REQUIRED_REVIEW_THREAD_RESOLUTION"
    echo "  - 許可マージ方法: ${ALLOWED_MERGE_METHODS[*]}"
    if [[ ${#REQUIRED_STATUS_CHECK_CONTEXTS[@]} -eq 0 ]]; then
        echo "  - required status checks: 未設定"
    else
        echo "  - required status checks: ${REQUIRED_STATUS_CHECK_CONTEXTS[*]}"
    fi
}

setup_notifications() {
    local repo_path="$OWNER/$REPO_NAME"

    if gh api -X PUT "repos/$repo_path/subscription" -f ignored=true > /dev/null 2>/dev/null; then
        echo "リポジトリ '$repo_path' の通知をIgnoreに設定しました。"
    else
        echo "注意: 通知設定に失敗しました。権限を確認してください。" >&2
    fi
}

# Dependabotセキュリティ機能の有効化
setup_dependabot_security() {
    local repo_path="$OWNER/$REPO_NAME"
    local success=true

    echo "Dependabotセキュリティ機能を設定中..."

    # Dependabot alerts を有効化
    if gh api -X PUT "repos/$repo_path/vulnerability-alerts" 2>/dev/null; then
        echo "  ✓ Dependabot alerts を有効化しました"
    else
        echo "  ✗ Dependabot alerts の有効化に失敗しました" >&2
        success=false
    fi

    # Dependabot security updates を有効化
    if gh api -X PUT "repos/$repo_path/automated-security-fixes" 2>/dev/null; then
        echo "  ✓ Dependabot security updates を有効化しました"
    else
        echo "  ✗ Dependabot security updates の有効化に失敗しました" >&2
        success=false
    fi

    # Dependency graph を有効化（リポジトリ設定経由）
    if gh api "repos/$repo_path" --method PATCH \
        --field has_vulnerability_alerts=true > /dev/null 2>/dev/null; then
        echo "  ✓ Dependency graph を有効化しました"
    else
        echo "  ✗ Dependency graph の有効化に失敗しました" >&2
        success=false
    fi

    # Dependabot version updates の状態を確認（情報提供のみ）
    echo "  ℹ Dependabot version updates の状態を確認中..."
    if gh api "repos/$repo_path/contents/.github/dependabot.yml" 2>/dev/null >/dev/null; then
        echo "  ⚠ Dependabot version updates が有効です（.github/dependabot.yml が存在）"
        echo "    無効化する場合は手動で .github/dependabot.yml を削除してください"
    else
        echo "  ✓ Dependabot version updates は無効です（.github/dependabot.yml なし）"
    fi

    if [ "$success" = true ]; then
        echo "Dependabotセキュリティ機能の設定が完了しました。"
    else
        echo "注意: 一部のセキュリティ機能の設定に失敗しました。権限を確認してください。" >&2
    fi
}

# メイン処理
main() {
    parse_args "$@"

    echo "=== GitHub リポジトリとルールセットの設定を開始します ==="
    echo "リポジトリ: $OWNER/$REPO_NAME"
    echo

    # リポジトリの存在確認（必須）
    ensure_repository_exists

    # ステップ1: リポジトリ設定更新
    echo "=== ステップ 1: リポジトリ設定の更新 ==="
    update_repository_settings
    echo

    # ステップ2: ルールセット設定
    echo "=== ステップ 2: ルールセットの設定 ==="
    if [ "$IS_PRIVATE" = "true" ]; then
        echo "プライベートリポジトリのため、ルールセット設定をスキップします（GitHub Pro が必要）。"
    else
        setup_ruleset
    fi
    echo

    # ステップ3: デフォルトブランチのブランチプロテクション設定
    echo "=== ステップ 3: デフォルトブランチのブランチプロテクション設定 ==="
    update_branch_protection
    echo

    # ステップ4: Dependabotセキュリティ機能の有効化
    echo "=== ステップ 4: Dependabotセキュリティ機能の有効化 ==="
    setup_dependabot_security
    echo

    # ステップ5: 通知設定
    echo "=== ステップ 5: 通知設定 ==="
    setup_notifications

    echo "=== 完了: すべての設定が完了しました ==="
}

# スクリプト実行
main "$@"
