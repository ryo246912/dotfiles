#!/usr/bin/env python3

import argparse
import json
import sys
from pathlib import Path

DEFAULT_SOURCE = Path.home() / ".config/rulesync/.rulesync/mcp.json"
DEFAULT_TARGET = Path.home() / ".copilot/mcp-config.json"


def fail(message: str) -> int:
    print(f"Error: {message}", file=sys.stderr)
    return 1


def expect_string(value: object, field: str, server_name: str) -> str:
    if not isinstance(value, str) or not value.strip():
        raise ValueError(f'MCP server "{server_name}" is missing a non-empty {field}.')
    return value


def expect_string_list(value: object, field: str, server_name: str) -> list[str]:
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise ValueError(f'MCP server "{server_name}" has an invalid {field}.')
    return value


def expect_string_map(value: object, field: str, server_name: str) -> dict[str, str]:
    if not isinstance(value, dict) or not all(isinstance(k, str) and isinstance(v, str) for k, v in value.items()):
        raise ValueError(f'MCP server "{server_name}" has an invalid {field}.')
    return value


# Copilot CLI accepts a narrower schema than the richer rulesync source.
def normalize_server(server_name: str, server: object) -> dict[str, object]:
    if not isinstance(server, dict):
        raise ValueError(f'MCP server "{server_name}" must be an object.')

    server_type = server.get("type")
    if not isinstance(server_type, str) or not server_type:
        if "url" in server:
            server_type = "http"
        elif "command" in server:
            server_type = "stdio"
        else:
            raise ValueError(f'MCP server "{server_name}" is missing a type.')

    normalized: dict[str, object] = {"type": server_type}

    if server_type == "stdio":
        normalized["command"] = expect_string(server.get("command"), "command", server_name)
        if "args" in server:
            normalized["args"] = expect_string_list(server["args"], "args", server_name)
        if "env" in server:
            normalized["env"] = expect_string_map(server["env"], "env", server_name)
    elif server_type in {"http", "sse"}:
        normalized["url"] = expect_string(server.get("url"), "url", server_name)
        if "headers" in server:
            normalized["headers"] = expect_string_map(server["headers"], "headers", server_name)
    else:
        if "command" in server:
            normalized["command"] = expect_string(server["command"], "command", server_name)
        if "args" in server:
            normalized["args"] = expect_string_list(server["args"], "args", server_name)
        if "env" in server:
            normalized["env"] = expect_string_map(server["env"], "env", server_name)
        if "url" in server:
            normalized["url"] = expect_string(server["url"], "url", server_name)
        if "headers" in server:
            normalized["headers"] = expect_string_map(server["headers"], "headers", server_name)

    if "tools" in server:
        normalized["tools"] = expect_string_list(server["tools"], "tools", server_name)

    return normalized


def load_source(path: Path) -> dict[str, object]:
    try:
        data = json.loads(path.read_text())
    except FileNotFoundError as exc:
        raise FileNotFoundError(f"source file not found: {path}") from exc
    except json.JSONDecodeError as exc:
        raise ValueError(f"source file is not valid JSON: {path}") from exc

    servers = data.get("mcpServers")
    if not isinstance(servers, dict):
        raise ValueError(f'source file "{path}" is missing an object "mcpServers".')

    normalized_servers: dict[str, object] = {}
    for server_name, server in servers.items():
        normalized_servers[server_name] = normalize_server(server_name, server)

    return {"mcpServers": normalized_servers}


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Normalize a rulesync MCP source file into GitHub Copilot CLI mcp-config.json."
    )
    parser.add_argument("source", nargs="?", default=str(DEFAULT_SOURCE))
    parser.add_argument("target", nargs="?", default=str(DEFAULT_TARGET))
    args = parser.parse_args()

    source_path = Path(args.source).expanduser()
    target_path = Path(args.target).expanduser()

    try:
        normalized = load_source(source_path)
    except (FileNotFoundError, ValueError) as exc:
        return fail(str(exc))

    target_path.parent.mkdir(parents=True, exist_ok=True)
    target_path.write_text(json.dumps(normalized, indent=2) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
