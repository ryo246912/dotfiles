#!/usr/bin/env bash

set -euo pipefail

find_go_bin() {
  local candidate=""
  for candidate in \
    "${MULTI_WORKTREE_GO_BIN:-}" \
    /opt/homebrew/bin/go \
    /usr/local/go/bin/go \
    /usr/local/bin/go \
    "$(command -v go 2>/dev/null || true)"; do
    if [[ -n "${candidate}" && -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

find_source_root() {
  local script_dir source_root candidate=""
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  source_root="$(cd "${script_dir}/../.." && pwd)"

  for candidate in \
    "${MULTI_WORKTREE_SOURCE_DIR:-}" \
    "${source_root}" \
    "${HOME}/.local/share/chezmoi"; do
    if [[ -n "${candidate}" && -f "${candidate}/tools/multi-worktree/go.mod" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

main() {
  local go_bin source_root cache_dir module_dir

  if ! go_bin="$(find_go_bin)"; then
    echo "[ERROR] go コマンドが見つかりません" >&2
    exit 1
  fi

  if ! source_root="$(find_source_root)"; then
    echo "[ERROR] tools/multi-worktree の source state が見つかりません" >&2
    echo "        MULTI_WORKTREE_SOURCE_DIR を設定するか、chezmoi の source state を配置してください" >&2
    exit 1
  fi

  module_dir="${source_root}/tools/multi-worktree"
  cache_dir="${MULTI_WORKTREE_CACHE_DIR:-${TMPDIR:-/tmp}/multi-worktree-go-cache}"
  mkdir -p "${cache_dir}/build" "${cache_dir}/mod" "${cache_dir}/path"

  export GOCACHE="${cache_dir}/build"
  export GOMODCACHE="${cache_dir}/mod"
  export GOPATH="${cache_dir}/path"

  cd "${module_dir}"
  exec "${go_bin}" run "./cmd/multi-worktree" "$@"
}

main "$@"
