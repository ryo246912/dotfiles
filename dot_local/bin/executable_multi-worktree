#!/usr/bin/env bash

# multi-worktree: マルチリポジトリ × git worktree 管理ツール
# 複数のリポジトリに対して、タスク単位で worktree を一括作成・管理する

set -euo pipefail

# カラー定義
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

# 設定ファイルのパス
readonly CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/multi-worktree"
readonly CONFIG_FILE="${CONFIG_DIR}/config.toml"

# ログ関数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

# 使用方法を表示
show_usage() {
    cat <<EOF
Usage: multi-worktree <subcommand> [options]

マルチリポジトリ × git worktree 管理ツール

サブコマンド:
  create <task-name> [--from=FROM_BRANCH] [--group=GROUP]  マルチrepoのworktreeを一括作成
  remove <task-name> [--force]          worktreeを一括削除
  list                                   タスク一覧表示（group列を含む）
  status <task-name>                     各repoの状態確認
  status main [--group=GROUP]           各repoのデフォルトブランチ（メインworktree）の状態確認
  sync <task-name> [repo...]            worktreeのHEADをメインworktreeにcheckout --detach
  sync <task-name> --all [repo...]      worktreeの内容をメインworktreeにrsyncで完全同期
  cd <task-name> [repo]                  worktreeディレクトリに移動（repo指定時はそのリポジトリへ）
  dev <task-name> [command]              devcontainerでコマンド実行（省略時は [dev_commands] からfzf選択）
  exec <task-name> <repo> -- <command>  worktreeの指定リポジトリディレクトリでコマンド実行
  exec main [--group=GROUP] <repo> -- <command>  メインworktreeの指定リポジトリディレクトリでコマンド実行
  open <task-name>                       VSCodeでworktreeを開く
  help                                   このヘルプを表示

オプション:
  --branch=BRANCH    checkout するブランチ名（createコマンドのみ、省略時はfzfで選択）
  --default-branch   各リポジトリのデフォルトブランチを checkout（createコマンドのみ）
  --group=GROUP      使用するリポジトリグループ（create/status mainコマンド、デフォルト: default）
  --force            git worktree remove失敗時も強制削除（removeコマンドのみ）

例:
  multi-worktree create feat/add-auth                              # fzf でブランチを選択して作成
  multi-worktree create feat/add-auth --branch=main               # 全リポジトリで main ブランチを checkout
  multi-worktree create feat/add-auth --default-branch            # 各リポジトリのデフォルトブランチを checkout
  multi-worktree create feat/new-feature --group=work --branch=develop
  multi-worktree list
  multi-worktree status feat/add-auth
  multi-worktree status main                       # デフォルトグループの各repoのデフォルトブランチ状態確認
  multi-worktree status main --group=work          # workグループの各repoのデフォルトブランチ状態確認
  multi-worktree sync feat/add-auth                    # 全リポジトリのHEADをcheckout --detach
  multi-worktree sync feat/add-auth --all              # 全リポジトリをrsyncで完全同期
  multi-worktree sync feat/add-auth repo1 repo2        # 特定リポジトリのHEADをcheckout --detach
  multi-worktree sync feat/add-auth --all repo1 repo2  # 特定リポジトリをrsyncで完全同期
  multi-worktree cd feat/add-auth
  multi-worktree dev feat/add-auth ccmanager
  multi-worktree exec feat/add-auth repo1 -- npm install
  multi-worktree exec feat/add-auth repo1 -- make build
  multi-worktree exec main repo1 -- npm install
  multi-worktree exec main --group=work repo1 -- make build
  multi-worktree open feat/add-auth
  multi-worktree remove feat/add-auth                  # 通常削除
  multi-worktree remove feat/add-auth --force          # 強制削除
EOF
}

# 強制削除を試行する（通常削除に失敗したら sudo を試す）
force_remove_dir() {
    local target="$1"

    [[ ! -e "$target" ]] && return 0

    if rm -rf "$target" 2>/dev/null; then
        return 0
    fi

    if command -v sudo >/dev/null 2>&1; then
        if sudo -n rm -rf "$target" 2>/dev/null; then
            return 0
        fi

        sudo rm -rf "$target"
        return $?
    fi

    return 1
}

# 設定ファイルの存在チェック
check_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        log_error "設定ファイルが見つかりません: $CONFIG_FILE"
        log_info "サンプル設定ファイルを作成してください:"
        log_info "  mkdir -p $CONFIG_DIR"
        log_info "  cat > $CONFIG_FILE <<'TOML'"
        log_info "[groups.default]"
        log_info "repos = [\"/path/to/repo1\", \"/path/to/repo2\"]"
        log_info "base_dir = \"../worktrees\""
        log_info "worktree_prefix = \"multi-worktree\""
        log_info ""
        log_info "[settings]"
        log_info "default_group = \"default\""
        log_info ""
        log_info "[dev_commands]"
        log_info "claude = \"claude --dangerously-skip-permissions\""
        log_info "copilot = \"copilot --yolo\""
        log_info "codex = \"codex --yolo\""
        log_info "TOML"
        return 1
    fi
}

# TOML 設定ファイルから値を読み込む（簡易実装）
# 引数: グループ名, キー名
get_config_value() {
    local group="$1"
    local key="$2"
    local in_group=false
    local value=""

    while IFS= read -r line; do
        # コメントと空行をスキップ
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        # グループセクションの検出
        if [[ "$line" =~ ^\[groups\.$group\] ]]; then
            in_group=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_group=false
            continue
        fi

        # グループ内でキーを探す
        if [[ "$in_group" == true ]] && [[ "$line" =~ ^[[:space:]]*$key[[:space:]]*= ]]; then
            value=$(echo "$line" | sed -E 's/^[[:space:]]*'"$key"'[[:space:]]*=[[:space:]]*//' | sed -E 's/^"(.*)"$/\1/' | sed -E "s/^'(.*)'$/\1/")
            echo "$value"
            return 0
        fi
    done < "$CONFIG_FILE"

    return 1
}

# 配列形式の設定値を読み込む
# 引数: グループ名, キー名
get_config_array() {
    local group="$1"
    local key="$2"
    local in_group=false
    local in_array=false
    local result=()

    while IFS= read -r line; do
        # コメントと空行をスキップ
        [[ "$line" =~ ^[[:space:]]*# ]] && continue

        # グループセクションの検出
        if [[ "$line" =~ ^\[groups\.$group\] ]]; then
            in_group=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_group=false
            in_array=false
            continue
        fi

        # 配列の開始を検出
        if [[ "$in_group" == true ]] && [[ "$line" =~ ^[[:space:]]*$key[[:space:]]*=[[:space:]]*\[ ]]; then
            in_array=true
            # 同じ行に要素がある場合
            local content=$(echo "$line" | sed -E 's/^[[:space:]]*'"$key"'[[:space:]]*=[[:space:]]*\[//' | sed 's/\]//')
            if [[ -n "$content" ]]; then
                IFS=',' read -ra items <<< "$content"
                for item in "${items[@]}"; do
                    item=$(echo "$item" | sed -E 's/^[[:space:]]*"(.*)"[[:space:]]*$/\1/' | sed -E "s/^[[:space:]]*'(.*)'[[:space:]]*$/\1/" | xargs)
                    [[ -n "$item" ]] && result+=("$item")
                done
            fi
            [[ "$line" =~ \] ]] && in_array=false
            continue
        fi

        # 配列要素の読み込み
        if [[ "$in_array" == true ]]; then
            if [[ "$line" =~ \] ]]; then
                in_array=false
                local content=$(echo "$line" | sed 's/\]//')
                if [[ -n "$content" ]]; then
                    IFS=',' read -ra items <<< "$content"
                    for item in "${items[@]}"; do
                        item=$(echo "$item" | sed -E 's/^[[:space:]]*"(.*)"[[:space:]]*$/\1/' | sed -E "s/^[[:space:]]*'(.*)'[[:space:]]*$/\1/" | xargs)
                        [[ -n "$item" ]] && result+=("$item")
                    done
                fi
            else
                IFS=',' read -ra items <<< "$line"
                for item in "${items[@]}"; do
                    item=$(echo "$item" | sed -E 's/^[[:space:]]*"(.*)"[[:space:]]*$/\1/' | sed -E "s/^[[:space:]]*'(.*)'[[:space:]]*$/\1/" | xargs)
                    [[ -n "$item" ]] && result+=("$item")
                done
            fi
        fi
    done < "$CONFIG_FILE"

    printf '%s\n' "${result[@]}"
}

# パス展開（~ と $HOME）
expand_path() {
    local path="$1"
    path="${path/#\~/$HOME}"
    path="${path//\$HOME/$HOME}"
    echo "$path"
}

# デフォルトグループの取得
get_default_group() {
    local value=""
    local in_settings=false

    while IFS= read -r line; do
        # コメントと空行をスキップ
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        # [settings] セクションの検出
        if [[ "$line" =~ ^\[settings\] ]]; then
            in_settings=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_settings=false
            continue
        fi

        # settings 内で default_group を探す
        if [[ "$in_settings" == true ]] && [[ "$line" =~ ^[[:space:]]*default_group[[:space:]]*= ]]; then
            value=$(echo "$line" | sed -E 's/^[[:space:]]*default_group[[:space:]]*=[[:space:]]*//' | sed -E 's/^"(.*)"$/\1/' | sed -E "s/^'(.*)'$/\1/")
            echo "$value"
            return 0
        fi
    done < "$CONFIG_FILE"

    echo "default"
}

# base_dirを絶対パスに解決する共通関数
resolve_base_dir() {
    local base_dir="$1"
    local group="$2"

    # すでに絶対パスの場合はそのまま返す
    if [[ "$base_dir" == /* ]]; then
        echo "$base_dir"
        return 0
    fi

    # 相対パスの場合、最初のリポジトリを基準に絶対パスを取得
    local repos=()
    while IFS= read -r repo; do
        repos+=("$repo")
    done < <(get_config_array "$group" "repos")

    if [[ ${#repos[@]} -gt 0 ]]; then
        local first_repo="${repos[0]}"
        first_repo="${first_repo/#\~/$HOME}"
        first_repo="${first_repo//\$HOME/$HOME}"

        if [[ -d "$first_repo" ]]; then
            # 最初のリポジトリのディレクトリからの相対パスとして解決
            local resolved_path=$(cd "$first_repo" && cd "$base_dir" 2>/dev/null && pwd)
            if [[ -n "$resolved_path" ]]; then
                echo "$resolved_path"
                return 0
            fi
        fi

        # first_repoが存在しない、またはcdに失敗した場合でも絶対パスを返す
        # realpath -m は存在しないパスでも正規化できる
        if command -v realpath &>/dev/null; then
            echo "$(realpath -m "$first_repo/$base_dir")"
            return 0
        fi
    fi

    # 解決できない場合は元のパスをそのまま返す
    echo "$base_dir"
}

# worktree のベースディレクトリを取得
get_worktree_base_dir() {
    local task_name="$1"
    local group="${2:-$(get_default_group)}"

    local base_dir=$(expand_path "$(get_config_value "$group" "base_dir")")
    local prefix=$(get_config_value "$group" "worktree_prefix")

    # base_dirを絶対パスに解決
    base_dir=$(resolve_base_dir "$base_dir" "$group")

    # タスク名から / を - に変換してディレクトリ名を作成
    local dir_name=$(echo "$task_name" | sed 's/\//-/g')

    echo "${base_dir}/${prefix}-${dir_name}"
}

# devcontainer up オプションの取得
get_devcontainer_up_opts() {
    local group="$1"
    local in_group=false
    local in_devcontainer=false
    local opts=""

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        if [[ "$line" =~ ^\[groups\.$group\] ]]; then
            in_group=true
            continue
        elif [[ "$line" =~ ^\[groups\.$group\.devcontainer\] ]]; then
            in_devcontainer=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_group=false
            in_devcontainer=false
            continue
        fi

        if [[ "$in_devcontainer" == true ]] && [[ "$line" =~ ^[[:space:]]*up_opts[[:space:]]*= ]]; then
            opts=$(echo "$line" | sed -E 's/^[[:space:]]*up_opts[[:space:]]*=[[:space:]]*//' | \
                   sed 's/\[//g' | sed 's/\]//g' | sed 's/"//g' | sed "s/'//g" | sed 's/,/ /g')
            break
        fi
    done < "$CONFIG_FILE"

    if [[ -z "$opts" ]]; then
        opts="--workspace-folder ."
    fi

    echo "$opts"
}

# devcontainer exec オプションの取得
get_devcontainer_exec_opts() {
    local group="$1"
    local in_devcontainer=false
    local opts=""

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        if [[ "$line" =~ ^\[groups\.$group\.devcontainer\] ]]; then
            in_devcontainer=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_devcontainer=false
            continue
        fi

        if [[ "$in_devcontainer" == true ]] && [[ "$line" =~ ^[[:space:]]*exec_opts[[:space:]]*= ]]; then
            opts=$(echo "$line" | sed -E 's/^[[:space:]]*exec_opts[[:space:]]*=[[:space:]]*//' | \
                   sed 's/\[//g' | sed 's/\]//g' | sed 's/"//g' | sed "s/'//g" | sed 's/,/ /g')
            break
        fi
    done < "$CONFIG_FILE"

    if [[ -z "$opts" ]]; then
        opts="--workspace-folder ."
    fi

    echo "$opts"
}

# skip_up_if_running 設定の取得
get_devcontainer_skip_up_if_running() {
    local in_settings=false
    local value=""

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        if [[ "$line" =~ ^\[settings\.devcontainer\] ]]; then
            in_settings=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_settings=false
            continue
        fi

        if [[ "$in_settings" == true ]] && [[ "$line" =~ ^[[:space:]]*skip_up_if_running[[:space:]]*= ]]; then
            value=$(echo "$line" | sed -E 's/^[[:space:]]*skip_up_if_running[[:space:]]*=[[:space:]]*//' | \
                    sed 's/"//g' | sed "s/'//g")
            break
        fi
    done < "$CONFIG_FILE"

    if [[ -z "$value" ]]; then
        echo "true"
    else
        echo "$value"
    fi
}

# [dev_commands] セクションからコマンド一覧を読み込む
# 出力形式: name\tcommand (TSV)
get_dev_commands() {
    local in_section=false

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// /}" ]] && continue

        if [[ "$line" =~ ^\[dev_commands\] ]]; then
            in_section=true
            continue
        elif [[ "$line" =~ ^\[.*\] ]]; then
            in_section=false
            continue
        fi

        if [[ "$in_section" == true ]]; then
            # key = "value" または key = 'value' 形式をパース
            if [[ "$line" =~ ^[[:space:]]*([^[:space:]=]+)[[:space:]]*=[[:space:]]*\"(.*)\"[[:space:]]*$ ]]; then
                printf '%s\t%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
            elif [[ "$line" =~ ^[[:space:]]*([^[:space:]=]+)[[:space:]]*=[[:space:]]*\'(.*)\'[[:space:]]*$ ]]; then
                printf '%s\t%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
            fi
        fi
    done < "$CONFIG_FILE"
}

# グループ内の全リポジトリを並列で fetch する
fetch_repos() {
    local repos=("$@")
    local tmpdir
    tmpdir=$(mktemp -d)
    local pids=()
    local expanded_repos=()

    log_info "全リポジトリを並列 fetch 中..."

    for repo in "${repos[@]}"; do
        local expanded_repo="${repo/#\~/$HOME}"
        expanded_repo="${expanded_repo//\$HOME/$HOME}"
        expanded_repos+=("$expanded_repo")
        local repo_name
        repo_name=$(basename "$expanded_repo")

        # バックグラウンドで fetch を実行
        (
            if git -C "$expanded_repo" fetch origin 2>/dev/null; then
                echo "success"
            else
                echo "fail"
            fi
        ) > "$tmpdir/$repo_name" &
        pids+=($!)
    done

    # 全バックグラウンドプロセスの完了を待つ
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # 結果を集計・表示
    local success_count=0
    local fail_count=0
    for expanded_repo in "${expanded_repos[@]}"; do
        local repo_name
        repo_name=$(basename "$expanded_repo")
        local result
        result=$(cat "$tmpdir/$repo_name" 2>/dev/null)
        if [[ "$result" == "success" ]]; then
            log_success "[$repo_name] fetch 完了"
            ((++success_count))
        else
            log_warn "[$repo_name] fetch に失敗しました（続行します）"
            ((++fail_count))
        fi
    done

    rm -rf "$tmpdir"
    log_info "fetch 完了: 成功 $success_count / 失敗 $fail_count"
}

# リポジトリのデフォルトブランチを取得する
# 優先順位: origin/HEAD symbolic-ref → main → master → フォールバック main
get_repo_default_branch() {
    local repo="$1"
    local default_branch

    # origin/HEAD の symbolic ref から取得（fetch 済みであれば最速）
    default_branch=$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's|^refs/remotes/origin/||')
    if [[ -n "$default_branch" ]]; then
        echo "$default_branch"
        return 0
    fi

    # フォールバック: main, master の順で存在チェック
    for branch in main master; do
        if git -C "$repo" show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
            echo "$branch"
            return 0
        fi
    done

    # 最終フォールバック
    echo "main"
}

# 全リポジトリで共通して checkout 可能なブランチ候補を収集する
# - origin/* のリモートトラッキングブランチ（worktree checkout 済みを除外）
collect_branch_candidates() {
    local repos=("$@")
    local first=true
    local common_candidates=""

    for repo in "${repos[@]}"; do
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"
        [[ ! -d "$repo" ]] && continue

        # worktree でチェックアウト中のブランチ一覧（除外リスト）
        local checked_out
        checked_out=$(git -C "$repo" worktree list --porcelain \
            | grep "^branch " | sed 's|^branch refs/heads/||')

        # リモートトラッキングブランチ（checkout 済みを除外、HEAD を除外）
        local candidates
        candidates=$(git -C "$repo" branch -r --format='%(refname:short)' \
            | grep '^origin/' \
            | sed 's|^origin/||' \
            | grep -v '^HEAD$' \
            | while read -r branch; do
                echo "$checked_out" | grep -qx "$branch" || echo "$branch"
              done)

        if $first; then
            common_candidates="$candidates"
            first=false
        else
            # 共通部分を残す（comm -12 は両方にある行）
            common_candidates=$(comm -12 \
                <(echo "$common_candidates" | sort) \
                <(echo "$candidates" | sort))
        fi
    done

    echo "$common_candidates"
}

# create サブコマンド
# 引数: task_name（worktreeディレクトリ名）, group, from_branch（ベースブランチ）
cmd_create() {
    local task_name="$1"
    local group="${2:-$(get_default_group)}"
    local from_branch="${3:-}"

    # 設定の読み込み
    local base_dir
    base_dir=$(get_config_value "$group" "base_dir")
    local prefix
    prefix=$(get_config_value "$group" "worktree_prefix")

    if [[ -z "$base_dir" ]] || [[ -z "$prefix" ]]; then
        log_error "グループ '$group' の設定が見つかりません"
        return 1
    fi

    # リポジトリリストの取得
    local repos=()
    while IFS= read -r repo; do
        repos+=("$repo")
    done < <(get_config_array "$group" "repos")

    if [[ ${#repos[@]} -eq 0 ]]; then
        log_error "グループ '$group' にリポジトリが設定されていません"
        return 1
    fi

    log_info "対象リポジトリ: ${#repos[@]} 個"

    # 全リポジトリを一括 fetch
    fetch_repos "${repos[@]}"

    # ブランチの解決: タスク名をブランチ名として使用し、ベースブランチから新規作成
    local from_label="${from_branch:-各リポジトリのデフォルトブランチ}"
    log_info "タスク '$task_name' の worktree を作成します (新規ブランチ: $task_name, ベース: $from_label, グループ: $group)"

    # worktree ベースディレクトリ（task_name から決定）
    local worktree_base_dir
    worktree_base_dir=$(get_worktree_base_dir "$task_name" "$group")

    log_info "作成先: $worktree_base_dir"

    # ベースディレクトリの作成
    mkdir -p "$worktree_base_dir"

    # 各リポジトリで worktree を作成
    local success_count=0
    local fail_count=0

    for repo in "${repos[@]}"; do
        # チルダ展開と環境変数展開
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"

        if [[ ! -d "$repo" ]]; then
            log_warn "リポジトリが見つかりません: $repo"
            ((++fail_count))
            continue
        fi

        local repo_name
        repo_name=$(basename "$repo")
        local worktree_path="${worktree_base_dir}/${repo_name}"

        log_info "[$repo_name] worktree を作成中..."

        # リポジトリディレクトリに移動（サブシェルでエラーが発生しても継続）
        (
            set +e  # エラーで停止しない
            cd "$repo" || exit 1

            local resolved_branch="$task_name"

            # worktree を作成（ブランチ存在チェック）
            # local ブランチ → remote のみ → ベースから新規作成 の順で確認
            local add_args=()
            if git show-ref --verify --quiet "refs/heads/$resolved_branch"; then
                # local ブランチが存在する
                add_args=("$resolved_branch")
            elif git show-ref --verify --quiet "refs/remotes/origin/$resolved_branch"; then
                # remote にのみ存在 → tracking ブランチとして作成
                add_args=("-b" "$resolved_branch" "origin/$resolved_branch")
            else
                # ブランチが存在しない → ベースブランチから新規作成
                local base_branch
                if [[ -n "$from_branch" ]]; then
                    base_branch="$from_branch"
                else
                    base_branch=$(get_repo_default_branch "$repo")
                fi
                local base_ref
                if git show-ref --verify --quiet "refs/remotes/origin/$base_branch"; then
                    base_ref="origin/$base_branch"
                elif git show-ref --verify --quiet "refs/heads/$base_branch"; then
                    base_ref="$base_branch"
                else
                    log_warn "[$repo_name] ベースブランチ '$base_branch' が見つかりません。スキップします"
                    exit 1
                fi
                add_args=("-b" "$resolved_branch" "$base_ref")
            fi

            local error_output
            if error_output=$(git worktree add "$worktree_path" "${add_args[@]}" 2>&1); then
                log_success "[$repo_name] worktree を作成しました: $worktree_path (ブランチ: $resolved_branch)"
                exit 0
            else
                log_error "[$repo_name] worktree の作成に失敗しました"
                echo "  エラー: $error_output"
                exit 1
            fi
        )

        # サブシェルの終了ステータスを確認
        if [[ $? -eq 0 ]]; then
            ((++success_count))
        else
            ((++fail_count))
        fi
    done

    log_info "完了: 成功 $success_count / 失敗 $fail_count"

    # devcontainer.json の生成
    if [[ $success_count -gt 0 ]]; then
        log_info "devcontainer.json を生成中..."
        generate_devcontainer "$task_name" "$worktree_base_dir" "${repos[@]}"
    fi

    if [[ $fail_count -eq 0 ]]; then
        log_success "すべての worktree が正常に作成されました"
    else
        log_warn "一部の worktree の作成に失敗しました"
    fi
}

# devcontainer.json の生成
generate_devcontainer() {
    local task_name="$1"
    local worktree_base_dir="$2"
    shift 2
    local repos=("$@")

    # worktree_base_dir を絶対パスに変換
    if command -v realpath &>/dev/null; then
        worktree_base_dir=$(realpath "$worktree_base_dir")
    else
        # realpathが利用できない場合、cdで絶対パスを取得
        worktree_base_dir=$(cd "$worktree_base_dir" && pwd)
    fi

    local devcontainer_dir="${worktree_base_dir}/.devcontainer"
    mkdir -p "$devcontainer_dir"

    local devcontainer_file="${devcontainer_dir}/devcontainer.json"

    # タスク名から / を - に変換
    local task_dir_name=$(echo "$task_name" | sed 's/\//-/g')
    local worktree_name="multi-worktree-${task_dir_name}"

    # ベーステンプレートのパス
    local base_template="$HOME/.config/devcontainer/devcontainer.json"

    if [[ ! -f "$base_template" ]]; then
        log_error "ベーステンプレートが見つかりません: $base_template"
        log_info "chezmoi apply を実行してベーステンプレートを配置してください"
        return 1
    fi

    # マウント設定を生成（JSON配列形式）
    local worktree_mounts="["
    local first=true

    for repo in "${repos[@]}"; do
        # チルダ展開と環境変数展開
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"
        [[ ! -d "$repo" ]] && continue

        local repo_name=$(basename "$repo")
        local worktree_path="${worktree_base_dir}/${repo_name}"

        [[ ! -d "$worktree_path" ]] && continue

        # 絶対パスに変換（realpathが利用可能な場合はそれを使用）
        if command -v realpath &>/dev/null; then
            worktree_path=$(realpath "$worktree_path")
        else
            # realpathが利用できない場合、cdで絶対パスを取得
            worktree_path=$(cd "$worktree_path" && pwd)
        fi

        if [[ "$first" == true ]]; then
            first=false
        else
            worktree_mounts+=","
        fi

        # worktree のマウント
        worktree_mounts+="\"type=bind,source=${worktree_path},target=/workspaces/${worktree_name}/${repo_name}\""

        # 実体リポジトリのマウント（.git アクセス用）
        worktree_mounts+=",\"type=bind,source=${repo},target=${repo}\""
    done

    worktree_mounts+="]"

    # jq を使ってベーステンプレートを読み込み、マウント設定を追加
    # JSONCのコメントを除去してからjqでパース
    if command -v jq &>/dev/null; then
        # // で始まる行コメントを除去（文字列内の // は保護）
        grep -v '^\s*//' "$base_template" | sed 's|^[[:space:]]*//.*||' | \
        jq --argjson new_mounts "$worktree_mounts" \
           --arg workspace_folder "/workspaces/${worktree_name}" \
           --arg task_name "$task_name" \
           '.mounts += $new_mounts |
            .workspaceFolder = $workspace_folder |
            .name = "Multi-worktree: " + $task_name' \
           > "$devcontainer_file"
    else
        log_error "jq コマンドが見つかりません。インストールしてください: mise install jq"
        return 1
    fi

    log_success "devcontainer.json を生成しました: $devcontainer_file"

    # .claude/settings.local.json を生成
    local claude_dir="${worktree_base_dir}/.claude"
    mkdir -p "$claude_dir"

    local claude_settings_file="${claude_dir}/settings.local.json"

    cat > "$claude_settings_file" <<'EOF'
{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CURRENT_DIR=$(basename \"$PWD\"); ssh -F ~/.config/ssh/config -o ConnectTimeout=2 -o StrictHostKeyChecking=no mac-host \"if [ -n \\\"$TMUX\\\" ]; then macos-notify-cli --title \\\"Claude Code\\\" --message \\\"${CURRENT_DIR}が確認待ちです\\\" --sound Glass --current-tmux; else macos-notify-cli --title \\\"Claude Code\\\" --message \\\"${CURRENT_DIR}が確認待ちです\\\" --sound Glass; fi\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CURRENT_DIR=$(basename \"$PWD\"); ssh -F ~/.config/ssh/config -o ConnectTimeout=2 -o StrictHostKeyChecking=no mac-host \"if [ -n \\\"$TMUX\\\" ]; then macos-notify-cli --title \\\"Claude Code\\\" --message \\\"${CURRENT_DIR}で作業が完了しました\\\" --sound Hero --current-tmux; else macos-notify-cli --title \\\"Claude Code\\\" --message \\\"${CURRENT_DIR}で作業が完了しました\\\" --sound Hero; fi\""
          }
        ]
      }
    ]
  }
}
EOF

    log_success ".claude/settings.local.json を生成しました: $claude_settings_file"
}

# 全グループ名を取得する
get_all_groups() {
    local groups=()
    local in_groups_section=false

    while IFS= read -r line; do
        # コメントと空行をスキップ
        [[ "$line" =~ ^[[:space:]]*# ]] && continue

        # [groups.xxx] の形式を検出
        if [[ "$line" =~ ^\[groups\.([^]]+)\] ]]; then
            local group_name="${BASH_REMATCH[1]}"
            groups+=("$group_name")
        fi
    done < "$CONFIG_FILE"

    printf '%s\n' "${groups[@]}"
}

# タスク名から worktree ディレクトリパスを検索する
# 全グループの base_dir を走査してタスクに対応するディレクトリを見つける
find_worktree_dir() {
    local task_name="$1"

    # タスク名から / を - に変換してディレクトリ名を作成
    local dir_name=$(echo "$task_name" | sed 's/\//-/g')

    # 全グループを走査
    local all_groups=()
    while IFS= read -r group; do
        all_groups+=("$group")
    done < <(get_all_groups)

    for group in "${all_groups[@]}"; do
        local base_dir=$(expand_path "$(get_config_value "$group" "base_dir")")
        local prefix=$(get_config_value "$group" "worktree_prefix")

        if [[ -z "$base_dir" ]] || [[ -z "$prefix" ]]; then
            continue
        fi

        # base_dirを絶対パスに解決
        base_dir=$(resolve_base_dir "$base_dir" "$group")

        # worktree ディレクトリパスを構築
        local worktree_dir="${base_dir}/${prefix}-${dir_name}"

        # ディレクトリが存在すれば、そのパスを返す
        if [[ -d "$worktree_dir" ]]; then
            echo "$worktree_dir"
            return 0
        fi
    done

    # 見つからなかった場合は空文字を返す
    return 1
}

# タスク名からグループ名を検索する
find_group_by_task() {
    local task_name="$1"

    # タスク名から / を - に変換してディレクトリ名を作成
    local dir_name=$(echo "$task_name" | sed 's/\//-/g')

    # 全グループを走査
    local all_groups=()
    while IFS= read -r group; do
        all_groups+=("$group")
    done < <(get_all_groups)

    for group in "${all_groups[@]}"; do
        local base_dir=$(expand_path "$(get_config_value "$group" "base_dir")")
        local prefix=$(get_config_value "$group" "worktree_prefix")

        if [[ -z "$base_dir" ]] || [[ -z "$prefix" ]]; then
            continue
        fi

        # base_dirを絶対パスに解決
        base_dir=$(resolve_base_dir "$base_dir" "$group")

        # worktree ディレクトリパスを構築
        local worktree_dir="${base_dir}/${prefix}-${dir_name}"

        # ディレクトリが存在すれば、そのグループ名を返す
        if [[ -d "$worktree_dir" ]]; then
            echo "$group"
            return 0
        fi
    done

    # 見つからなかった場合は空文字を返す
    return 1
}

# list サブコマンド
cmd_list() {
    # 全グループを取得
    local all_groups=()
    while IFS= read -r group; do
        all_groups+=("$group")
    done < <(get_all_groups)

    # グループが1つも見つからない場合
    if [[ ${#all_groups[@]} -eq 0 ]]; then
        log_error "設定ファイルにグループが見つかりません" >&2
        return 1
    fi

    # 各グループのworktreeを表示
    for group in "${all_groups[@]}"; do
        local base_dir=$(expand_path "$(get_config_value "$group" "base_dir")")
        local prefix=$(get_config_value "$group" "worktree_prefix")

        if [[ -z "$base_dir" ]] || [[ -z "$prefix" ]]; then
            continue
        fi

        # base_dirを絶対パスに解決（共通関数を使用）
        base_dir=$(resolve_base_dir "$base_dir" "$group")

        # worktree ディレクトリを検索（TSV形式で出力）
        if [[ ! -d "$base_dir" ]]; then
            continue
        fi

        for dir in "$base_dir"/${prefix}-*; do
            # globパターンにマッチするものがない場合、パターン自体が返される
            # その場合はスキップ
            if [[ ! -e "$dir" ]]; then
                continue
            fi

            if [[ -d "$dir" ]]; then
                local task_dir_name=$(basename "$dir" | sed "s/^${prefix}-//")
                local task_name=$(echo "$task_dir_name" | sed 's/-/\//g')

                # リポジトリ数をカウント
                local repo_count=$(find "$dir" -mindepth 1 -maxdepth 1 -type d ! -name ".*" | wc -l | tr -d ' ')

                # devcontainer の有無を確認
                local has_devcontainer=""
                if [[ -f "$dir/.devcontainer/devcontainer.json" ]]; then
                    has_devcontainer="devcontainer"
                fi

                # TSV形式で出力: <task-name>\t<group>\t<path>\t<repo-count> repos\t[devcontainer]
                echo -e "${task_name}\t${group}\t${dir}\t${repo_count} repos\t${has_devcontainer}"
            fi
        done
    done
}

# status サブコマンド
cmd_status() {
    local task_name="$1"

    local worktree_base_dir=$(find_worktree_dir "$task_name")

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    log_info "タスク '$task_name' のステータス"
    log_info "ディレクトリ: $worktree_base_dir"
    echo ""

    # 各リポジトリのステータスを表示
    for repo_dir in "$worktree_base_dir"/*; do
        if [[ -d "$repo_dir" ]] && [[ ! "$(basename "$repo_dir")" =~ ^\. ]]; then
            local repo_name=$(basename "$repo_dir")

            echo -e "${BLUE}=== $repo_name ===${NC}"

            (
                cd "$repo_dir"

                # ブランチ情報
                local branch=$(git branch --show-current 2>/dev/null || echo "unknown")
                echo "ブランチ: $branch"

                # 変更状況
                if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
                    echo -e "${YELLOW}変更あり${NC}"
                    git status --short
                else
                    echo -e "${GREEN}変更なし${NC}"
                fi

                # 最新のコミット
                echo ""
                echo "最新のコミット:"
                git log --oneline -3 2>/dev/null || echo "コミット履歴なし"
            )

            echo ""
        fi
    done
}

# status main サブコマンド
# 設定に登録された各リポジトリ（メインworktree）のステータスを表示する
cmd_status_main() {
    local group="${1:-$(get_default_group)}"

    # リポジトリ一覧を取得
    local repos=()
    while IFS= read -r repo; do
        repos+=("$repo")
    done < <(get_config_array "$group" "repos")

    if [[ ${#repos[@]} -eq 0 ]]; then
        log_error "グループ '$group' のリポジトリが設定されていません"
        return 1
    fi

    log_info "グループ '$group' の各リポジトリ（デフォルトブランチ）のステータス"
    echo ""

    for repo in "${repos[@]}"; do
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"

        if [[ ! -d "$repo" ]]; then
            echo -e "${YELLOW}=== $(basename "$repo") ===${NC}"
            echo -e "${RED}ディレクトリが見つかりません: $repo${NC}"
            echo ""
            continue
        fi

        local repo_name=$(basename "$repo")
        echo -e "${BLUE}=== $repo_name ===${NC}"

        (
            cd "$repo"

            # ブランチ情報
            local branch=$(git branch --show-current 2>/dev/null || echo "unknown")
            local default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
                | sed 's|^refs/remotes/origin/||')
            if [[ -z "$default_branch" ]]; then
                for b in main master; do
                    if git show-ref --verify --quiet "refs/remotes/origin/$b" 2>/dev/null; then
                        default_branch="$b"
                        break
                    fi
                done
            fi

            echo "ブランチ: $branch${default_branch:+ (デフォルト: $default_branch)}"

            # 変更状況
            if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
                echo -e "${YELLOW}変更あり${NC}"
                git status --short
            else
                echo -e "${GREEN}変更なし${NC}"
            fi

            # 最新のコミット
            echo ""
            echo "最新のコミット:"
            git log --oneline -3 2>/dev/null || echo "コミット履歴なし"
        )

        echo ""
    done
}

# cd サブコマンド
cmd_cd() {
    local task_name="$1"
    local repo_name="${2:-}"

    local worktree_base_dir=$(find_worktree_dir "$task_name")

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    local target_dir="$worktree_base_dir"

    if [[ -n "$repo_name" ]]; then
        local repo_dir="${worktree_base_dir}/${repo_name}"
        if [[ ! -d "$repo_dir" ]]; then
            log_error "リポジトリ '$repo_name' の worktree が見つかりません: $repo_dir"
            return 1
        fi
        target_dir="$repo_dir"
    fi

    log_info "worktree ディレクトリに移動します: $target_dir"
    log_success "新しいシェルを起動します。exit で戻ります。"

    # worktree ディレクトリに移動
    cd "$target_dir" || return 1

    # シェルを起動（SHELL 環境変数を使用、デフォルトは bash）
    local shell="${SHELL:-/bin/bash}"
    exec "$shell"
}

# dev サブコマンド
cmd_dev() {
    local task_name="$1"
    shift

    if [[ $# -eq 0 ]]; then
        # 設定ファイルの [dev_commands] から fzf で選択
        local dev_cmds
        dev_cmds=$(get_dev_commands)

        if [[ -z "$dev_cmds" ]]; then
            log_error "実行するコマンドを指定してください（設定ファイルに [dev_commands] を追加するか、引数で直接指定）"
            return 1
        fi

        local selected
        selected=$(echo "$dev_cmds" | fzf \
            --header="実行するコマンドを選択" \
            --delimiter=$'\t' \
            --with-nth=1,2 \
            --preview="echo 'コマンド: {2}'" \
            --preview-window="bottom:3")

        if [[ -z "$selected" ]]; then
            log_warn "選択がキャンセルされました"
            return 0
        fi

        local selected_cmd
        selected_cmd=$(echo "$selected" | cut -f2)

        # 選択されたコマンドを positional parameters に設定
        read -ra _cmd_args <<< "$selected_cmd"
        set -- "${_cmd_args[@]}"
    fi

    local command="$*"

    local worktree_base_dir=$(find_worktree_dir "$task_name")

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    local group=$(find_group_by_task "$task_name")

    if [[ -z "$group" ]]; then
        log_error "タスク '$task_name' のグループが見つかりません"
        return 1
    fi

    log_info "タスク '$task_name' で devcontainer を起動します"

    # 設定の読み込み
    local up_opts=$(get_devcontainer_up_opts "$group")
    local exec_opts=$(get_devcontainer_exec_opts "$group")
    local skip_up=$(get_devcontainer_skip_up_if_running)

    # worktree ディレクトリに移動
    cd "$worktree_base_dir" || return 1

    # devcontainer が起動しているかチェック
    local is_running=false
    if [[ "$skip_up" == "true" ]]; then
        # コンテナが起動しているかチェック（簡易版）
        local container_name=$(basename "$worktree_base_dir")
        if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "$container_name"; then
            is_running=true
            log_info "devcontainer は既に起動しています"
        fi
    fi

    # devcontainer up の実行
    if [[ "$is_running" == "false" ]]; then
        log_info "devcontainer を起動中..."

        # オプションを配列として解析して安全に実行
        local -a up_args
        read -ra up_args <<< "$up_opts"
        devcontainer up "${up_args[@]}"

        if [[ $? -ne 0 ]]; then
            log_error "devcontainer の起動に失敗しました"
            return 1
        fi
    fi

    # devcontainer exec の実行
    log_info "コマンドを実行中: $command"

    # オプションを配列として解析して安全に実行
    local -a exec_args
    read -ra exec_args <<< "$exec_opts"
    devcontainer exec "${exec_args[@]}" "$@"

    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        log_error "コマンドの実行に失敗しました (終了コード: $exit_code)"
        return $exit_code
    fi

    log_success "コマンドが正常に完了しました"
}

# exec サブコマンド
# worktreeの指定リポジトリディレクトリでコマンドを直接実行する
# 引数: task_name, repo_name, -- <command...>
cmd_exec() {
    local task_name="$1"
    local repo_name="$2"
    shift 2

    # -- セパレータをスキップ
    if [[ "${1:-}" == "--" ]]; then
        shift
    fi

    if [[ $# -eq 0 ]]; then
        log_error "実行するコマンドを指定してください（-- の後に指定）"
        return 1
    fi

    local worktree_base_dir
    worktree_base_dir=$(find_worktree_dir "$task_name") || {
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    }

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    local worktree_path="${worktree_base_dir}/${repo_name}"

    if [[ ! -d "$worktree_path" ]]; then
        log_error "リポジトリ '$repo_name' の worktree が見つかりません: $worktree_path"
        return 1
    fi

    log_info "[$repo_name] コマンド実行: $*"

    log_info "ディレクトリ: $worktree_path"
    echo ""

    (
        cd "$worktree_path" || exit 1
        "$@"
    )

    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        log_error "コマンドが失敗しました (終了コード: $exit_code)"
        return $exit_code
    fi

    log_success "コマンドが正常に完了しました"
}

# exec main サブコマンド
# 設定に登録された各リポジトリ（メインworktree）の指定リポジトリでコマンドを実行する
# 引数: group, repo_name, -- <command...>
cmd_exec_main() {
    local group="$1"
    local repo_name="$2"
    shift 2

    # -- セパレータをスキップ
    if [[ "${1:-}" == "--" ]]; then
        shift
    fi

    if [[ $# -eq 0 ]]; then
        log_error "実行するコマンドを指定してください（-- の後に指定）"
        return 1
    fi

    # グループのリポジトリ一覧を取得
    local repos=()
    while IFS= read -r repo; do
        repos+=("$repo")
    done < <(get_config_array "$group" "repos")

    if [[ ${#repos[@]} -eq 0 ]]; then
        log_error "グループ '$group' のリポジトリが設定されていません"
        return 1
    fi

    # repo_name に一致するリポジトリを検索
    local target_repo=""
    for repo in "${repos[@]}"; do
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"
        if [[ "$(basename "$repo")" == "$repo_name" ]]; then
            target_repo="$repo"
            break
        fi
    done

    if [[ -z "$target_repo" ]]; then
        log_error "リポジトリ '$repo_name' がグループ '$group' に見つかりません"
        return 1
    fi

    if [[ ! -d "$target_repo" ]]; then
        log_error "リポジトリディレクトリが見つかりません: $target_repo"
        return 1
    fi

    log_info "[$repo_name] コマンド実行 (main): $*"
    log_info "ディレクトリ: $target_repo"
    echo ""

    (
        cd "$target_repo" || exit 1
        "$@"
    )

    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        log_error "コマンドが失敗しました (終了コード: $exit_code)"
        return $exit_code
    fi

    log_success "コマンドが正常に完了しました"
}

# sync サブコマンド
cmd_sync() {
    local task_name="$1"
    local use_all="$2"
    shift 2
    local selected_repos=("$@")  # 選択されたリポジトリ名（引数で渡される）

    local worktree_base_dir=$(find_worktree_dir "$task_name")

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    local group=$(find_group_by_task "$task_name")

    if [[ -z "$group" ]]; then
        log_error "タスク '$task_name' のグループが見つかりません"
        return 1
    fi

    if [[ "$use_all" == "true" ]]; then
        log_info "タスク '$task_name' の worktree をメインworktreeにrsyncで完全同期します"
    else
        log_info "タスク '$task_name' の worktree のHEADをメインworktreeにcheckout --detachします"
    fi
    log_info "ディレクトリ: $worktree_base_dir"
    echo ""

    # リポジトリリストの取得
    local repos=()
    while IFS= read -r repo; do
        repos+=("$repo")
    done < <(get_config_array "$group" "repos")

    # 選択されたリポジトリがある場合、それらのみをフィルタリング
    if [[ ${#selected_repos[@]} -gt 0 ]]; then
        local filtered_repos=()
        for selected in "${selected_repos[@]}"; do
            local found=false
            for repo in "${repos[@]}"; do
                local repo_name=$(basename "$repo")
                if [[ "$repo_name" == "$selected" ]]; then
                    filtered_repos+=("$repo")
                    found=true
                    break
                fi
            done
            if [[ "$found" == false ]]; then
                log_warn "リポジトリ '$selected' は設定に存在しません"
            fi
        done

        if [[ ${#filtered_repos[@]} -eq 0 ]]; then
            log_error "有効なリポジトリが選択されていません"
            return 1
        fi

        repos=("${filtered_repos[@]}")
        log_info "選択されたリポジトリ: ${#repos[@]} 個"
    fi

    # 各リポジトリで同期を実行
    local success_count=0
    local fail_count=0

    for repo in "${repos[@]}"; do
        # チルダ展開と環境変数展開
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"
        [[ ! -d "$repo" ]] && continue

        local repo_name=$(basename "$repo")
        local worktree_path="${worktree_base_dir}/${repo_name}"

        if [[ ! -d "$worktree_path" ]]; then
            log_warn "[$repo_name] worktree が見つかりません: $worktree_path"
            ((++fail_count))
            continue
        fi

        log_info "[$repo_name] 同期中..."

        # サブシェルで同期処理を実行（エラーが発生しても継続）
        (
            set +e  # エラーで停止しない
            cd "$worktree_path" || exit 1

            if [[ ! -d "$repo" ]]; then
                log_error "[$repo_name] リポジトリディレクトリが見つかりません: $repo"
                exit 1
            fi

            # 現在のHEADをdetachモードでrepoにチェックアウト
            local current_head
            current_head="$(git rev-parse HEAD)"

            if ! git -C "$repo" checkout --detach "$current_head" 2>/dev/null; then
                log_error "[$repo_name] checkout --detach に失敗しました"
                exit 1
            fi

            if [[ "$use_all" == "true" ]]; then
                # rsyncでファイルを同期（.gitを除外）
                if ! rsync -a --exclude '.git' "$PWD/" "$repo/" 2>/dev/null; then
                    log_error "[$repo_name] rsync に失敗しました"
                    exit 1
                fi
                log_success "[$repo_name] 完全同期完了: $repo"
            else
                log_success "[$repo_name] checkout --detach 完了: $repo"
            fi

            exit 0
        )

        # サブシェルの終了ステータスを確認
        if [[ $? -eq 0 ]]; then
            ((++success_count))
        else
            ((++fail_count))
        fi
    done

    echo ""
    log_info "完了: 成功 $success_count / 失敗 $fail_count"

    if [[ $fail_count -eq 0 ]]; then
        log_success "すべてのリポジトリの同期が完了しました"
    else
        log_warn "一部のリポジトリの同期に失敗しました"
        return 1
    fi
}

# open サブコマンド
cmd_open() {
    local task_name="$1"

    local worktree_base_dir=$(find_worktree_dir "$task_name")

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    log_info "VSCode で worktree ディレクトリを開きます: $worktree_base_dir"

    # VSCodeで開く
    code "$worktree_base_dir"

    if [[ $? -eq 0 ]]; then
        log_success "VSCode を起動しました"
    else
        log_error "VSCode の起動に失敗しました"
        return 1
    fi
}

# remove サブコマンド
cmd_remove() {
    local task_name="$1"
    local force="${2:-false}"

    local worktree_base_dir=$(find_worktree_dir "$task_name")

    if [[ -z "$worktree_base_dir" ]] || [[ ! -d "$worktree_base_dir" ]]; then
        log_error "タスク '$task_name' の worktree が見つかりません"
        return 1
    fi

    local group=$(find_group_by_task "$task_name")

    if [[ -z "$group" ]]; then
        log_error "タスク '$task_name' のグループが見つかりません"
        return 1
    fi

    log_warn "タスク '$task_name' の worktree を削除します"
    log_info "ディレクトリ: $worktree_base_dir"
    if [[ "$force" == "true" ]]; then
        log_warn "強制削除モード: 削除失敗時に権限調整と強制削除を試行します"
    fi
    echo ""

    # 確認
    read -p "本当に削除しますか? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "キャンセルしました"
        return 0
    fi

    # リポジトリリストの取得
    local repos=()
    while IFS= read -r repo; do
        repos+=("$repo")
    done < <(get_config_array "$group" "repos")

    # 各リポジトリで worktree を削除
    local success_count=0
    local fail_count=0

    for repo in "${repos[@]}"; do
        # チルダ展開と環境変数展開
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"
        [[ ! -d "$repo" ]] && continue

        local repo_name=$(basename "$repo")
        local worktree_path="${worktree_base_dir}/${repo_name}"

        if [[ ! -d "$worktree_path" ]]; then
            continue
        fi

        log_info "[$repo_name] worktree を削除中..."

        # git worktree remove を試行
        local remove_status=0
        if (
            set +e
            cd "$repo" || exit 1
            git worktree remove "$worktree_path" --force &>/dev/null
            exit $?
        ); then
            remove_status=0
        else
            remove_status=$?
        fi

        if [[ $remove_status -eq 0 ]]; then
            log_success "[$repo_name] worktree を削除しました"
            ((++success_count))
        else
            if [[ -d "$worktree_path" ]]; then
                if force_remove_dir "$worktree_path"; then
                    log_warn "[$repo_name] git worktree remove 失敗。権限を無視して削除しました"
                    ((++success_count))
                else
                    log_error "[$repo_name] ディレクトリの強制削除に失敗しました"
                    ((++fail_count))
                fi
            else
                log_success "[$repo_name] ディレクトリは既に削除済みです"
                ((++success_count))
            fi
        fi
    done

    log_info "git worktree の登録情報をクリーンアップ中..."
    for repo in "${repos[@]}"; do
        repo="${repo/#\~/$HOME}"
        repo="${repo//\$HOME/$HOME}"
        [[ ! -d "$repo" ]] && continue

        local repo_name=$(basename "$repo")
        (
            cd "$repo"
            git worktree prune &>/dev/null
        )
        log_info "[$repo_name] git worktree prune を実行しました"
    done

    # .devcontainer ディレクトリなど、git worktree remove で削除されない残存ファイルを削除
    if [[ -d "$worktree_base_dir" ]]; then
        # 空でないディレクトリが残っている場合のみ削除
        if [[ -n "$(ls -A "$worktree_base_dir" 2>/dev/null)" ]]; then
            if force_remove_dir "$worktree_base_dir"; then
                log_success "残存ディレクトリを削除しました: $worktree_base_dir"
            else
                log_error "残存ディレクトリの削除に失敗しました: $worktree_base_dir"
                ((++fail_count))
            fi
        fi
    fi

    log_info "完了: 成功 $success_count / 失敗 $fail_count"
}

# メイン処理
main() {
    if [[ $# -eq 0 ]]; then
        show_usage
        return 1
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        create)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            local task_name="$1"
            local group
            group=$(get_default_group)
            local from_branch=""

            shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --from=*)
                        from_branch="${1#*=}"
                        ;;
                    --group=*)
                        group="${1#*=}"
                        ;;
                    --*)
                        log_error "不明なオプション: $1"
                        return 1
                        ;;
                    *)
                        log_error "不明な引数: $1"
                        return 1
                        ;;
                esac
                shift
            done

            cmd_create "$task_name" "$group" "$from_branch"
            ;;

        list)
            check_config || return 1
            cmd_list
            ;;

        status)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            if [[ "$1" == "main" ]]; then
                shift
                local group
                group=$(get_default_group)
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --group=*)
                            group="${1#*=}"
                            ;;
                        *)
                            log_error "不明なオプション: $1"
                            return 1
                            ;;
                    esac
                    shift
                done
                cmd_status_main "$group"
            else
                cmd_status "$1"
            fi
            ;;

        sync)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            local task_name="$1"
            local use_all="false"
            shift

            local selected_repos=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --all)
                        use_all="true"
                        ;;
                    --*)
                        log_error "不明なオプション: $1"
                        return 1
                        ;;
                    *)
                        selected_repos+=("$1")
                        ;;
                esac
                shift
            done

            cmd_sync "$task_name" "$use_all" "${selected_repos[@]+"${selected_repos[@]}"}"
            ;;

        cd)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            cmd_cd "$1" "${2:-}"
            ;;

        dev)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            local task_name="$1"
            shift

            cmd_dev "$task_name" "$@"
            ;;

        exec)
            check_config || return 1

            if [[ $# -lt 2 ]]; then
                log_error "タスク名とリポジトリ名を指定してください"
                show_usage
                return 1
            fi

            if [[ "$1" == "main" ]]; then
                shift
                local group
                group=$(get_default_group)
                local repo_name=""

                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --group=*)
                            group="${1#*=}"
                            shift
                            ;;
                        --)
                            shift
                            break
                            ;;
                        *)
                            repo_name="$1"
                            shift
                            break
                            ;;
                    esac
                done

                if [[ -z "$repo_name" ]]; then
                    log_error "リポジトリ名を指定してください"
                    return 1
                fi

                cmd_exec_main "$group" "$repo_name" "$@"
            else
                local task_name="$1"
                local repo_name="$2"
                shift 2

                cmd_exec "$task_name" "$repo_name" "$@"
            fi
            ;;

        open)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            cmd_open "$1"
            ;;

        remove)
            check_config || return 1

            if [[ $# -eq 0 ]]; then
                log_error "タスク名を指定してください"
                show_usage
                return 1
            fi

            local task_name="$1"
            local force=false
            shift

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --force)
                        force=true
                        ;;
                    *)
                        log_error "不明なオプション: $1"
                        return 1
                        ;;
                esac
                shift
            done

            cmd_remove "$task_name" "$force"
            ;;

        help|--help|-h)
            show_usage
            ;;

        *)
            log_error "不明なサブコマンド: $subcommand"
            show_usage
            return 1
            ;;
    esac
}

main "$@"
