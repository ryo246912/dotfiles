{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000"
  },
  "model": "claude-3-7-sonnet-20250219",
  "thinking": {
    "enabled": false,
    "effort": "low"
  },
  "cleanupPeriodDays": 36500,
  "permissions": {
    "allow": [
      "Bash(mise list:*)",
      "Bash(ccmanager --help)",
      "Bash(xcode-select:*)",
      "Bash(claude mcp:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(shfmt:*)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(**/.env.*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccusage statusline --visual-burn-rate emoji"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "expo-deployment@expo-plugins": true
  },
  "bash": {
    "blockUnlistedCommands": true
  },
  "git": {
    "includeCoAuthor": false
  }
}
