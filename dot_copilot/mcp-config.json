{
  "mcpServers": {
    "io.github.ChromeDevTools/chrome-devtools-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@0.13.0",
        "--browser-url=http://localhost:9222"
      ]
    },
    "makenotion/notion-mcp-server": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "AWS Billing and Cost Management MCP Server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.billing-cost-management-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "AppAdministratorAccess-Root",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "CloudWatch MCP Server(staging)": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.cloudwatch-mcp-server@latest"
      ],
      "env": {
        "AWS_PROFILE": "AppAdministratorAccess-Giho-Sea-Staging",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    }
  }
}
