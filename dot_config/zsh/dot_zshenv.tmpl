# FIXME: .zprofile読み込まれない関係でPATHが通らなかったため暫定的に記載
# パスの重複を除く
typeset -U path PATH

if [ "$(uname)" = "Darwin" ]; then
  export ANDROID_HOME=$HOME/Library/Android/sdk
  path=(
    $HOME/{,.local/}{,s}bin(N)
    /{opt,usr}/local/{,s}bin(N)
    /opt/homebrew/opt/coreutils/libexec/gnubin(N)
    /opt/homebrew/opt/findutils/libexec/gnubin(N)
    /opt/homebrew/opt/grep/libexec/gnubin(N)
    /opt/homebrew/opt/gnu-sed/libexec/gnubin(N)
    $HOME/.cargo/bin(N)
    $HOME/go/bin(N)
    $ANDROID_HOME/emulator(N)
    $ANDROID_HOME/platform-tools(N)
    $path
  )
else
  path=(
    $HOME/{,.local/}{,s}bin(N)
    /{opt,usr}/local/{,s}bin(N)
    $HOME/.cargo/bin(N)
    $HOME/go/bin(N)
    $path
  )
fi

if [ "$(uname)" = "Darwin" ]; then
{{ if (lookPath "brew") -}}
{{ output "brew" "shellenv" | trim }}
{{- end }}
fi

# HOST_ENV をホスト名で解決する
if [ -z "${HOST_ENV:-}" ]; then
    _host_id="${MISE_HOST_ID:-$(scutil --get LocalHostName 2>/dev/null || hostname -s 2>/dev/null)}"
    _host_env="$(awk -F'[[:space:]]*=[[:space:]]*' -v h="$_host_id" \
        '!/^[[:space:]]*(#|$)/ && $1 == h {print $2; exit}' \
        "${XDG_CONFIG_HOME:-$HOME/.config}/zsh/host-env.map" 2>/dev/null)"
    [ -n "$_host_env" ] && export HOST_ENV="$_host_env"
    unset _host_id _host_env
fi

# HOST_ENV から MISE_ENV を導出
if [ -z "${MISE_ENV:-}" ] && [ -n "${HOST_ENV:-}" ]; then
    export MISE_ENV="$HOST_ENV"
fi

if command -v mise >/dev/null 2>&1; then
{{ if (lookPath "mise") -}}
{{ output "mise" "activate" "zsh" "--shims" | trim }}
{{- end }}
fi

# Editor
export EDITOR=nvim
export VISUAL=nvim
