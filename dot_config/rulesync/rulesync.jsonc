// rulesync manages internal/custom rules and skills, while external skills are managed via the npx skills lockfile.
{
  "targets": ["claudecode", "codexcli", "geminicli", "copilot", "copilotcli"],
  "features": {
    "claudecode": ["rules", "skills", "hooks"],
    "codexcli": ["rules", "skills"],
    "geminicli": ["rules", "commands", "hooks"],
    "copilot": ["rules"],
    "copilotcli": ["rules", "mcp"],
  },
  "delete": false,
  "verbose": false,
  "silent": false,
  "global": true,
}
