{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/mcp-schema.json",
  "mcpServers": {
    "io.github.ChromeDevTools/chrome-devtools-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@0.13.0",
        "--browser-url=http://localhost:9222"
      ],
      "gallery": "https://api.mcp.github.com",
      "version": "0.13.0"
    },
    "makenotion/notion-mcp-server": {
      "url": "https://mcp.notion.com/mcp",
      "type": "http"
    },
    "AWS Billing and Cost Management MCP Server": {
      "command": "uvx",
      "args": ["awslabs.billing-cost-management-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "AppAdministratorAccess-Root",
        "AWS_REGION": "ap-northeast-1"
      },
      "disabled": false,
      "autoApprove": [],
      "type": "stdio"
    },
    "CloudWatch MCP Server(staging)": {
      "autoApprove": [],
      "disabled": false,
      "command": "uvx",
      "args": ["awslabs.cloudwatch-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "AppAdministratorAccess-Giho-Sea-Staging",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "transportType": "stdio",
      "type": "stdio"
    },
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  }
}
