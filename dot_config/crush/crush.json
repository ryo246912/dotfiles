{
  "$schema": "https://raw.githubusercontent.com/charmbracelet/crush/main/schema.json",
  "tools": {},
  "options": {
    "context_paths": ["AGENTS.md", "CLAUDE.md", "GEMINI.md", "QWEN.md"],
    "skills_paths": ["~/.config/crush/skills"],
    "disable_metrics": true,
    "initialize_as": "AGENTS.md",
    "progress": true,
    "tui": {
      "compact_mode": true,
      "diff_mode": "unified",
      "completions": {
        "max_depth": 8,
        "max_items": 200
      }
    }
  }
}
