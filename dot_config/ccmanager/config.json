{
  "shortcuts": {
    "returnToMenu": {
      "ctrl": true,
      "key": "e"
    },
    "cancel": {
      "key": "escape"
    }
  },
  "statusHooks": {
    "idle": {
      "command": "$HOME/.local/bin/ai-agent-notify --agent ccmanager --event idle --path \"$CCMANAGER_WORKTREE_PATH\" --branch \"$CCMANAGER_WORKTREE_BRANCH\"",
      "enabled": true
    },
    "waiting_input": {
      "command": "$HOME/.local/bin/ai-agent-notify --agent ccmanager --event waiting_input --path \"$CCMANAGER_WORKTREE_PATH\" --branch \"$CCMANAGER_WORKTREE_BRANCH\"",
      "enabled": true
    }
  },
  "worktree": {
    "autoDirectory": true,
    "autoDirectoryPattern": "../worktrees/{project}-{branch}",
    "copySessionData": true,
    "sortByLastSession": false
  },
  "command": {
    "command": "claude"
  },
  "commandPresets": {
    "presets": [
      {
        "id": "1",
        "name": "Claude A1 (resume)",
        "command": "claude",
        "args": ["--resume"],
        "fallbackArgs": []
      },
      {
        "id": "2",
        "name": "Claude A2 (resume)",
        "command": "claude2",
        "args": ["--resume"],
        "fallbackArgs": [],
        "detectionStrategy": "claude"
      },
      {
        "id": "3",
        "name": "Claude A1 (no resume)",
        "command": "claude",
        "args": [""],
        "detectionStrategy": "claude"
      },
      {
        "id": "4",
        "name": "Claude A2 (no resume)",
        "command": "claude2",
        "args": [""],
        "detectionStrategy": "claude"
      },
      {
        "id": "1752767057209",
        "name": "Gemini",
        "command": "gemini",
        "detectionStrategy": "gemini",
        "args": ["-s"]
      },
      {
        "id": "codex",
        "name": "Codex",
        "command": "codex",
        "args": ["resume", "--yolo"],
        "detectionStrategy": "codex",
        "fallbackArgs": ["--yolo"]
      },
      {
        "id": "copilot",
        "name": "Copilot",
        "command": "copilot",
        "detectionStrategy": "github-copilot",
        "args": ["--resume", "--yolo"],
        "fallbackArgs": ["--yolo"]
      }
    ],
    "defaultPresetId": "1",
    "selectPresetOnStart": true
  },
  "worktreeHooks": {}
}
