#compdef multi-worktree
# multi-worktree zsh completion

_multi_worktree() {
    local -a subcommands
    subcommands=(
        'create:マルチrepoのworktreeを一括作成'
        'recreate:不足しているworktreeを補充し、task設定を再生成'
        'remove:worktreeを一括削除'
        'list:タスク一覧表示'
        'status:各repoの状態確認'
        'sync:worktreeの内容をメインworktreeに同期（リポジトリ選択可）'
        'cd:worktreeディレクトリに移動'
        'dev:devcontainerで実行、または --sbx で Docker Sandboxes を起動'
        'exec:worktreeの指定リポジトリディレクトリでコマンド実行'
        'open:VSCodeでworktreeを開く'
        'help:ヘルプを表示'
    )

    local -a task_names
    task_names=(${(f)"$(multi-worktree list 2>/dev/null | awk '{print $1}')"})

    # リポジトリ名を補完する関数（git worktreeのみ対象）
    _multi_worktree_repo_names() {
        local task_name="$1"
        if [[ -n "$task_name" ]]; then
            local task_path
            task_path=$(multi-worktree list 2>/dev/null | awk -F '\t' -v task="$task_name" '$1 == task {print $3}' | head -n 1)
            if [[ -n "$task_path" ]] && [[ -d "$task_path" ]]; then
                local -a repo_names
                local d name
                for d in "$task_path"/*/; do
                    [[ -d "$d" ]] || continue
                    name=$(basename "$d")
                    [[ "$name" == .* ]] && continue
                    [[ -f "$d/.git" ]] || [[ -d "$d/.git" ]] || continue
                    repo_names+=("$name:worktreeのディレクトリで実行")
                done
                _describe 'repository name' repo_names
            fi
        fi
    }

    # メインworktreeのリポジトリ名を補完する関数（既存タスクのworktreeからrepo名を取得）
    _multi_worktree_main_repo_names() {
        local task_path
        task_path=$(multi-worktree list 2>/dev/null | awk -F '\t' 'NR==1{print $3}')
        if [[ -n "$task_path" ]] && [[ -d "$task_path" ]]; then
            local -a repo_names
            local d name
            for d in "$task_path"/*/; do
                [[ -d "$d" ]] || continue
                name=$(basename "$d")
                [[ "$name" == .* ]] && continue
                [[ -f "$d/.git" ]] || [[ -d "$d/.git" ]] || continue
                repo_names+=("$name:メインworktreeのディレクトリで実行")
            done
            _describe 'repository name' repo_names
        fi
    }

    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '1: :->subcommand' \
        '*:: :->args' \
        && return 0

    case $state in
        subcommand)
            _describe -t subcommands 'multi-worktree subcommand' subcommands
            ;;
        args)
            case $line[1] in
                create)
                    _arguments \
                        '1:task-name:' \
                        '--group=[グループ名]:group:'
                    ;;
                recreate)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'task name' task_names
                    else
                        _arguments '--group=[グループ名]:group:'
                    fi
                    ;;
                remove)
                    _arguments \
                        "1:task-name:(($task_names))" \
                        '--force[git worktree remove失敗時も強制削除]'
                    ;;
                status)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a main_args
                        main_args=('main:各repoのデフォルトブランチ（メインworktree）の状態確認')
                        _describe 'special' main_args
                        _describe 'task name' task_names
                    elif [[ "${words[2]}" == "main" ]]; then
                        _arguments '--group=[グループ名]:group:'
                    fi
                    ;;
                cd)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'task name' task_names
                    elif [[ $CURRENT -eq 3 ]]; then
                        _multi_worktree_repo_names "${words[2]}"
                    fi
                    ;;
                open)
                    _arguments \
                        "1:task-name:(($task_names))"
                    ;;
                sync)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'task name' task_names
                    else
                        local task_name="${words[2]}"
                        local -a sync_opts
                        sync_opts=('--all:rsyncで完全同期（checkout --detach + rsync）')
                        _describe 'options' sync_opts
                        _multi_worktree_repo_names "$task_name"
                    fi
                    ;;
                dev)
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe 'task name' task_names
                    elif [[ $CURRENT -ge 3 ]]; then
                        local sandbox_mode=false word current_word
                        current_word="${words[CURRENT]}"
                        for word in "${words[@]}"; do
                            if [[ "$word" == "--sbx" || "$word" == --sbx=* ]]; then
                                sandbox_mode=true
                                break
                            fi
                        done

                        if [[ "$sandbox_mode" == true ]]; then
                            local -a sandbox_agents sandbox_opts
                            sandbox_agents=(claude codex copilot docker-agent gemini kiro opencode shell)
                            sandbox_opts=(--name --name= --cli --cli= --)

                            if [[ "${words[CURRENT-1]}" == "--sbx" ]]; then
                                compadd -a sandbox_agents
                            elif [[ "${words[CURRENT-1]}" == "--cli" ]]; then
                                compadd sbx docker
                            elif [[ "$current_word" == --sbx=* ]]; then
                                compadd -P '--sbx=' claude codex copilot docker-agent gemini kiro opencode shell
                            elif [[ "$current_word" == --cli=* ]]; then
                                compadd -P '--cli=' sbx docker
                            elif [[ "$current_word" == --* ]]; then
                                compadd -a sandbox_opts
                            else
                                _message 'agent arguments'
                            fi
                        else
                            local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/multi-worktree/config.toml"
                            if [[ -f "$config_file" ]]; then
                                local -a _dev_vals _dev_disp
                                local _in_sec=false _ln
                                while IFS= read -r _ln; do
                                    [[ "$_ln" =~ '^[[:space:]]*#' ]] && continue
                                    if [[ "$_ln" == '[dev_commands]' ]]; then
                                        _in_sec=true; continue
                                    elif [[ "$_ln" =~ '^\[' ]]; then
                                        _in_sec=false; continue
                                    fi
                                    if $_in_sec && [[ "$_ln" =~ '^[[:space:]]*([^[:space:]=]+)[[:space:]]*=[[:space:]]*"(.*)"[[:space:]]*$' ]]; then
                                        _dev_vals+=("${match[2]}")
                                        _dev_disp+=("${match[1]} -- ${match[2]}")
                                    fi
                                done < "$config_file"
                                [[ ${#_dev_vals[@]} -gt 0 ]] && compadd -d _dev_disp -a _dev_vals
                            fi
                        fi
                    fi
                    ;;
                exec)
                    if [[ $CURRENT -eq 2 ]]; then
                        local -a main_args
                        main_args=('main:メインworktreeのリポジトリでコマンド実行')
                        _describe 'special' main_args
                        _describe 'task name' task_names
                    elif [[ "${words[2]}" == "main" ]]; then
                        # exec main の場合
                        if [[ $CURRENT -eq 3 ]]; then
                            # --group か repo名
                            local -a main_opts
                            main_opts=('--group=[グループ名]:group:')
                            _arguments "${main_opts[@]}"
                            _multi_worktree_main_repo_names
                        elif [[ $CURRENT -eq 4 ]] && [[ "${words[3]}" == --group=* ]]; then
                            # --group=GROUP の次はrepo名
                            _multi_worktree_main_repo_names
                        elif [[ "${words[-1]}" != "--" ]]; then
                            local -a sep
                            sep=('--:コマンドセパレータ')
                            _describe 'separator' sep
                        else
                            _command_names -e
                        fi
                    else
                        # exec <task> の場合
                        if [[ $CURRENT -eq 3 ]]; then
                            _multi_worktree_repo_names "${words[2]}"
                        elif [[ $CURRENT -eq 4 ]] && [[ "${words[3]}" != "--" ]]; then
                            local -a sep
                            sep=('--:コマンドセパレータ')
                            _describe 'separator' sep
                        else
                            _command_names -e
                        fi
                    fi
                    ;;
                list)
                    # no arguments
                    ;;
                help)
                    # no arguments
                    ;;
            esac
            ;;
    esac

    return 0
}

_multi_worktree "$@"
