# https://github.com/raphamorim/rio/blob/main/CHANGELOG.md
[fonts]
size = 11
[fonts.regular]
family = "HackGen35 Console NF"
[fonts.bold]
family = "HackGen35 Console NF"

[renderer]
performance = "High"
backend = "Automatic"

# Padding-x
padding-x = 0

# Option as Alt
#
# This config only works on MacOs.
# Possible choices: 'both', 'left' and 'right'.
option_as_alt = 'both'

[window]
width = 1200
height = 800
opacity = 0.95
decorations = "Disabled"  # windowバーを非表示
mode = "Maximized"

# Navigation
#
# "mode" - Define navigation mode: CollapsedTab, BottomTab, TopTab, Breadcrumb, Plain.
# "clickable" - Enable click on tabs to switch.
# "use-current-path" - Use same path whenever a new tab is created.
# "color-automation" - Set a specific color for the tab whenever a specific program is running.
#
[navigation]
mode = "Plain"  # ナビゲーションバーを非表示
clickable = true
use-current-path = true

# Shell
#
# You can set `shell.program` to the path of your favorite shell, e.g. `/bin/fish`.
# Entries in `shell.args` are passed unmodified as arguments to the shell.
#
# Default:
#   - (macOS) user login shell
#   - (Linux/BSD) user login shell
#   - (Windows) powershell
#
{{ if eq .chezmoi.os "darwin" -}}
shell = { program = "/bin/zsh", args = ["--login","-c 'tmux attach || tmux'"] }
{{ else -}}
[shell]
program = "wsl ~"
args = ["-d Ubuntu-20.04"]
# args = ["-d Ubuntu-20.04","-e 'tmux attach || tmux'"]
{{- end }}

# Startup directory
#
# Directory the shell is started in. If this is unset the working
# directory of the parent process will be used.
#
# This configuration only has effect if use-fork is disabled
working_dir = "~"

# Editor
#
# You can set your default editor to open configuration file
editor = "vim"

# Disable render when unfocused
#
# This property disable renderer processes while Rio is unfocused.
disable-renderer-when-unfocused = false

# Use fork
#
# Defaults for POSIX-based systems (Windows is not configurable):
# MacOS: spawn processes
# Linux/BSD: fork processes
#
use-fork = false

# Colors
# https://github.com/dracula/rio-terminal/blob/9ef402c48b5540f60397c478c89500415a235a3a/dracula.toml
[colors]
background       = '#191724'
foreground       = '#ffffff'
cursor           = '#ffffff'
tabs             = '#808080'
tabs-active      = '#feff00'

# normal
black            = '#000000'
red              = '#fe0100'
green            = '#33ff00'
yellow           = '#feff00'
blue             = '#0066ff'
magenta          = '#cc00ff'
cyan             = '#00ffff'
white            = '#d0d0d0'

# light
light-black      = '#808080'
light-red        = '#fe0100'
light-green      = '#33ff00'
light-yellow     = '#feff00'
light-blue       = '#0066ff'
light-magenta    = '#cc00ff'
light-cyan       = '#00ffff'
light-white      = '#FFFFFF'

# Bindings
# https://raphamorim.io/rio/docs/key-bindings
# Note: Use "esc" field (not "bytes") for sending escape sequences in current Rio versions
{{ if eq .chezmoi.os "darwin" -}}
# super = command
[bindings]
keys = [
  { key = "d",        with = "super",                 esc = "\u0002%"}       , # ctrl + b → %(ペインを左右に分割)
  { key = "d",        with = "super | shift",         esc = "\u0002\""}      , # ctrl + b → "(ペインを上下に分割)
  { key = "c",        with = "super",                 esc = "\u0002["}       , # ctrl + b → [(コピーモード)
  # { key = "e",      with = "super",                 esc = "\u0002P"}       , # ctrl + b → P(easymotion search、カスタム)
  { key = "e",        with = "super",                 esc = "\u0002 "}       , # ctrl + b → space(tmux-thumbs、カスタム)
  { key = "e",        with = "super | shift",         esc = "\u0002Q"}       , # ctrl + b → Q(easymotion easycopy、カスタム)
  { key = "f",        with = "super",                 esc = "\u0002\u0006"}  , # ctrl + b → ctrl + f(コピーモード→検索、カスタム)
  # { key = "j",      with = "super",                 esc = "\u0002O"}       , # ctrl + b → O(mode切替→easy motion jump line、カスタム)
  { key = "l",        with = "super",                 esc = "\u0002s"}       , # ctrl + b → s(ペイン一覧表示)
  { key = "l",        with = "super | shift",         esc = "\u0002w"}       , # ctrl + b → w(ウィンドウ一覧表示)
  { key = "o",        with = "super",                 esc = "\u0002R"}       , # ctrl + b → R(easymotion quickopen、カスタム)
  { key = "p",        with = "super",                 esc = "\u0002\u0010"}  , # ctrl + b → ctrl + p(popup window、カスタム)
  { key = "p",        with = "super | shift",         esc = "\u0002\u0014"}  , # ctrl + b → ctrl + t(popup window、カスタム)
  { key = "r",        with = "super",                 esc = "\u0002r"}       , # ctrl + b → r(.tmux.confの再読込、カスタム)
  { key = "s",        with = "super",                 esc = "\u0002e"}       , # ctrl + b → e(synchronize-panesのON/OFF、カスタム)
  { key = "r",        with = "super | shift",         esc = "\u0002\u0012"}  , # ctrl + b → ctrl + r(tmux-resurrect 復元)
  { key = "s",        with = "super | shift",         esc = "\u0002\u0013"}  , # ctrl + b → ctrl + s(tmux-resurrect 保存)
  { key = "t",        with = "super",                 action = "None"}       , # 既存 cmd + t を無効にする
  { key = "t",        with = "super",                 esc = "\u0002c"}       , # ctrl + b → c(ウィンドウの作成)
  { key = "t",        with = "super | shift",         action = "None"}       , # cmd + shift + t(タブ作成)を無効にする
  { key = "x",        with = "super",                 esc = "\u0002x"}       , # ctrl + b → x(ウィンドウの破棄)
  { key = "w",        with = "super | shift",         esc = "\u0002d"}       , # ctrl + b → d(ウィンドウのデタッチ)
  { key = "z",        with = "super",                 esc = "\u0002z"}       , # ctrl + b → z(ペインの一時拡大/縮小)
  { key = "left",     with = "super",                 esc = "\u0002h"}       , # ctrl + b → h(左のペインに移動、カスタム)
  { key = "down",     with = "super",                 esc = "\u0002j"}       , # ctrl + b → j(下のペインに移動、カスタム)
  { key = "up",       with = "super",                 esc = "\u0002k"}       , # ctrl + b → k(上のペインに移動、カスタム)
  { key = "right",    with = "super",                 esc = "\u0002l"}       , # ctrl + b → l(右のペインに移動、カスタム)
  { key = "left",     with = "super | shift",         esc = "\u0002\u0008"}  , # ctrl + b → ctrl + h(ペインを左に広げる、カスタム)
  { key = "down",     with = "super | shift",         esc = "\u0002\u0009"}  , # ctrl + b → ctrl + i(ペインを下に広げる、カスタム)
  { key = "up",       with = "super | shift",         esc = "\u0002\u000b"}  , # ctrl + b → ctrl + k(ペインを上に広げる、カスタム)
  { key = "right",    with = "super | shift",         esc = "\u0002\u000c"}  , # ctrl + b → ctrl + l(ペインを右に広げる、カスタム)
  { key = "up",       with = "super | shift | alt",   esc = "\u0002{"}       , # ctrl + b → {(ペインを前に入れ替え)
  { key = "down",     with = "super | shift | alt",   esc = "\u0002}"}       , # ctrl + b → }(ペインを後ろに入れ替え)
  { key = "[",        with = "super",                 esc = "\u0002\u0009"}  , # ctrl + b → ctrl + i(前のペインに移動、カスタム)
  { key = "]",        with = "super",                 esc = "\u0002\u001d"}  , # ctrl + b → ctrl + ](次のペインに移動、カスタム)
  { key = "[",        with = "super | shift",         esc = "\u0002p"}       , # ctrl + b → p(前のウィンドウに移動)
  { key = "]",        with = "super | shift",         esc = "\u0002n"}       , # ctrl + b → n(次のウィンドウに移動)
  { key = "[",        with = "super | shift | alt",   esc = "\u0002\u001e"}  , # ctrl + b → ctrl + ^(ウィンドウを前に入れ替え、カスタム)
  { key = "]",        with = "super | shift | alt",   esc = "\u0002\u001d"}  , # ctrl + b → ctrl + ](ウィンドウを後ろに入れ替え、カスタム)
  # { key = "space",  with = "super",                 esc = "\u0002 "}       , # ctrl + b → space(popup window、カスタム)
  { key = "1",        with = "super",                 esc = "\u00021"}       , # ctrl + b → 1(ウィンドウ1に移動)
  { key = "2",        with = "super",                 esc = "\u00022"}       , # ctrl + b → 2(ウィンドウ2に移動)
  { key = "3",        with = "super",                 esc = "\u00023"}       , # ctrl + b → 3(ウィンドウ3に移動)
  { key = "4",        with = "super",                 esc = "\u00024"}       , # ctrl + b → 4(ウィンドウ4に移動)
  { key = "5",        with = "super",                 esc = "\u00025"}       , # ctrl + b → 5(ウィンドウ5に移動)
  { key = "6",        with = "super",                 esc = "\u00026"}       , # ctrl + b → 6(ウィンドウ6に移動)
  { key = "7",        with = "super",                 esc = "\u00027"}       , # ctrl + b → 7(ウィンドウ7に移動)
  { key = "8",        with = "super",                 esc = "\u00028"}       , # ctrl + b → 8(ウィンドウ8に移動)
  { key = "9",        with = "super",                 esc = "\u00029"}       , # ctrl + b → 9(ウィンドウ9に移動)
]
