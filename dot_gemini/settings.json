{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "GitHub"
  },
  "general": {
    "previewFeatures": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "36500d",
      "maxCount": 10000
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.gemini/hooks/rtk-hook-gemini.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse"
    },
    "modular-mcp": {
      "command": "npx",
      "args": ["-y", "@kimuson/modular-mcp", "$HOME/.claude/modular-mcp.json"]
    }
  }
}
