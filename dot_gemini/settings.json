{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "GitHub"
  },
  "general": {
    "previewFeatures": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "36500d",
      "maxCount": 10000
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "mcpServers": {
    // https://docs.devin.ai/ja/work-with-devin/deepwiki-mcp#sse-server-sent-events-/sse
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse"
    },
    // https://github.com/d-kimuson/modular-mcp
    "modular-mcp": {
      "command": "npx",
      "args": ["-y", "@kimuson/modular-mcp", "$HOME/.claude/modular-mcp.json"]
    }
  }
}
